<UserControl x:Class="veteran_logistic.Transactions.LoadingRegisters.Views.EditLoadingRegisterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Background="{DynamicResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="{StaticResource StandardBorderThickness}"
                Padding="{StaticResource Medium}">
            <TextBlock Text="Edit Loading Register"
                       Style="{StaticResource HeadingTextBlockStyle}"
                       VerticalAlignment="Center" />
        </Border>

        <!-- Form -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="{StaticResource Large}">
            <StackPanel>
                <!-- Validation Error -->
                <Border Background="{DynamicResource ErrorBrush}"
                        BorderBrush="{DynamicResource ErrorBrush}"
                        BorderThickness="{StaticResource StandardBorderThickness}"
                        CornerRadius="{StaticResource StandardCornerRadius}"
                        Padding="{StaticResource Small}"
                        Margin="{StaticResource Small}"
                        Visibility="{Binding ValidationError, Converter={StaticResource StringToVisibilityConverter}}">
                    <TextBlock Text="{Binding ValidationError}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{DynamicResource TextOnPrimaryBrush}"
                               TextWrapping="Wrap" />
                </Border>

                <!-- Challan Number (Read-only) -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="{StaticResource StandardBorderThickness}"
                        CornerRadius="{StaticResource StandardCornerRadius}"
                        Padding="{StaticResource Medium}"
                        Margin="{StaticResource Small}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" MinWidth="150" />
                            <ColumnDefinition Width="*" MinWidth="200" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Challan Number"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   VerticalAlignment="Center"
                                   Margin="{StaticResource ExtraSmall}" />
                        <TextBox Grid.Column="1"
                                 Text="{Binding ChallanNumber, Mode=OneWay}"
                                 IsReadOnly="True"
                                 Height="{StaticResource StandardControlHeight}"
                                 Margin="{StaticResource ExtraSmall}"
                                 Background="{DynamicResource DisabledBrush}" />
                    </Grid>
                </Border>

                <!-- Main Form Grid -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="{StaticResource StandardBorderThickness}"
                        CornerRadius="{StaticResource StandardCornerRadius}"
                        Padding="{StaticResource Medium}"
                        Margin="{StaticResource Small}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" MinWidth="150" />
                            <ColumnDefinition Width="*" MinWidth="200" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="Auto" MinWidth="150" />
                            <ColumnDefinition Width="*" MinWidth="200" />
                        </Grid.ColumnDefinitions>

                        <!-- Row 1: Loading Date, TP Number -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Loading Date"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   VerticalAlignment="Center"
                                   Margin="{StaticResource ExtraSmall}" />
                        <DatePicker Grid.Row="0" Grid.Column="1"
                                    SelectedDate="{Binding LoadingDate}"
                                    Height="{StaticResource StandardControlHeight}"
                                    Margin="{StaticResource ExtraSmall}" />

                        <TextBlock Grid.Row="0" Grid.Column="3" Text="TP Number"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   VerticalAlignment="Center"
                                   Margin="{StaticResource ExtraSmall}" />
                        <TextBox Grid.Row="0" Grid.Column="4"
                                 Text="{Binding TPNumber, UpdateSourceTrigger=PropertyChanged}"
                                 Height="{StaticResource StandardControlHeight}"
                                 Margin="{StaticResource ExtraSmall}" />

                        <!-- Row 2: Consignor, Consignee -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Consignor"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   VerticalAlignment="Center"
                                   Margin="{StaticResource ExtraSmall}" />
                        <ComboBox Grid.Row="1" Grid.Column="1"
                                  ItemsSource="{Binding Customers}"
                                  SelectedValuePath="Id"
                                  DisplayMemberPath="CustomerName"
                                  SelectedValue="{Binding ConsignorId}"
                                  Height="{StaticResource StandardControlHeight}"
                                  Margin="{StaticResource ExtraSmall}"
                                  IsEditable="True"
                                  IsTextSearchEnabled="True"
                                  TextSearch.TextPath="CustomerName" />

                        <TextBlock Grid.Row="1" Grid.Column="3" Text="Consignee"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   VerticalAlignment="Center"
                                   Margin="{StaticResource ExtraSmall}" />
                        <ComboBox Grid.Row="1" Grid.Column="4"
                                  ItemsSource="{Binding Customers}"
                                  SelectedValuePath="Id"
                                  DisplayMemberPath="CustomerName"
                                  SelectedValue="{Binding ConsigneeId}"
                                  Height="{StaticResource StandardControlHeight}"
                                  Margin="{StaticResource ExtraSmall}"
                                  IsEditable="True"
                                  IsTextSearchEnabled="True"
                                  TextSearch.TextPath="CustomerName" />

                        <!-- Row 3: Source, Destination -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Source"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   VerticalAlignment="Center"
                                   Margin="{StaticResource ExtraSmall}" />
                        <ComboBox Grid.Row="2" Grid.Column="1"
                                  ItemsSource="{Binding SourceDestinations}"
                                  SelectedValuePath="Id"
                                  DisplayMemberPath="LocationName"
                                  SelectedValue="{Binding SourceId}"
                                  Height="{StaticResource StandardControlHeight}"
                                  Margin="{StaticResource ExtraSmall}"
                                  IsEditable="True"
                                  IsTextSearchEnabled="True"
                                  TextSearch.TextPath="LocationName" />

                        <TextBlock Grid.Row="2" Grid.Column="3" Text="Destination"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   VerticalAlignment="Center"
                                   Margin="{StaticResource ExtraSmall}" />
                        <ComboBox Grid.Row="2" Grid.Column="4"
                                  ItemsSource="{Binding SourceDestinations}"
                                  SelectedValuePath="Id"
                                  DisplayMemberPath="LocationName"
                                  SelectedValue="{Binding DestinationId}"
                                  Height="{StaticResource StandardControlHeight}"
                                  Margin="{StaticResource ExtraSmall}"
                                  IsEditable="True"
                                  IsTextSearchEnabled="True"
                                  TextSearch.TextPath="LocationName" />

                        <!-- Row 4: Vehicle, Union/Vendor -->
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Vehicle"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   VerticalAlignment="Center"
                                   Margin="{StaticResource ExtraSmall}" />
                        <ComboBox Grid.Row="3" Grid.Column="1"
                                  ItemsSource="{Binding Vehicles}"
                                  SelectedValuePath="Id"
                                  DisplayMemberPath="VehicleNumber"
                                  SelectedValue="{Binding VehicleId}"
                                  Height="{StaticResource StandardControlHeight}"
                                  Margin="{StaticResource ExtraSmall}"
                                  IsEditable="True"
                                  IsTextSearchEnabled="True"
                                  TextSearch.TextPath="VehicleNumber" />

                        <TextBlock Grid.Row="3" Grid.Column="3" Text="Union/Vendor"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   VerticalAlignment="Center"
                                   Margin="{StaticResource ExtraSmall}" />
                        <ComboBox Grid.Row="3" Grid.Column="4"
                                  ItemsSource="{Binding Vendors}"
                                  SelectedValuePath="Id"
                                  DisplayMemberPath="Name"
                                  SelectedValue="{Binding UnionVendorId}"
                                  Height="{StaticResource StandardControlHeight}"
                                  Margin="{StaticResource ExtraSmall}"
                                  IsEditable="True"
                                  IsTextSearchEnabled="True"
                                  TextSearch.TextPath="Name" />

                        <!-- Row 5: Material, Rate -->
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Material"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   VerticalAlignment="Center"
                                   Margin="{StaticResource ExtraSmall}" />
                        <ComboBox Grid.Row="4" Grid.Column="1"
                                  ItemsSource="{Binding Materials}"
                                  SelectedValuePath="Id"
                                  DisplayMemberPath="MaterialName"
                                  SelectedValue="{Binding MaterialId}"
                                  Height="{StaticResource StandardControlHeight}"
                                  Margin="{StaticResource ExtraSmall}"
                                  IsEditable="True"
                                  IsTextSearchEnabled="True"
                                  TextSearch.TextPath="MaterialName" />

                        <TextBlock Grid.Row="4" Grid.Column="3" Text="Rate"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   VerticalAlignment="Center"
                                   Margin="{StaticResource ExtraSmall}" />
                        <TextBox Grid.Row="4" Grid.Column="4"
                                 Text="{Binding Rate, UpdateSourceTrigger=PropertyChanged}"
                                 Height="{StaticResource StandardControlHeight}"
                                 Margin="{StaticResource ExtraSmall}" />

                        <!-- Row 6: Gross Weight, Tare Weight -->
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Gross Weight"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   VerticalAlignment="Center"
                                   Margin="{StaticResource ExtraSmall}" />
                        <TextBox Grid.Row="5" Grid.Column="1"
                                 Text="{Binding GrossWeight, UpdateSourceTrigger=PropertyChanged}"
                                 Height="{StaticResource StandardControlHeight}"
                                 Margin="{StaticResource ExtraSmall}" />

                        <TextBlock Grid.Row="5" Grid.Column="3" Text="Tare Weight"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   VerticalAlignment="Center"
                                   Margin="{StaticResource ExtraSmall}" />
                        <TextBox Grid.Row="5" Grid.Column="4"
                                 Text="{Binding TareWeight, UpdateSourceTrigger=PropertyChanged}"
                                 Height="{StaticResource StandardControlHeight}"
                                 Margin="{StaticResource ExtraSmall}" />

                        <!-- Row 7: Loading Weight (Calculated), Gross Amount (Calculated) -->
                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Loading Weight"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   VerticalAlignment="Center"
                                   Margin="{StaticResource ExtraSmall}" />
                        <TextBox Grid.Row="6" Grid.Column="1"
                                 Text="{Binding LoadingWeight, Mode=OneWay}"
                                 IsReadOnly="True"
                                 Height="{StaticResource StandardControlHeight}"
                                 Margin="{StaticResource ExtraSmall}"
                                 Background="{DynamicResource DisabledBrush}" />

                        <TextBlock Grid.Row="6" Grid.Column="3" Text="Gross Amount"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   VerticalAlignment="Center"
                                   Margin="{StaticResource ExtraSmall}" />
                        <TextBox Grid.Row="6" Grid.Column="4"
                                 Text="{Binding GrossAmount, Mode=OneWay}"
                                 IsReadOnly="True"
                                 Height="{StaticResource StandardControlHeight}"
                                 Margin="{StaticResource ExtraSmall}"
                                 Background="{DynamicResource DisabledBrush}" />
                    </Grid>
                </Border>

                <!-- Additional Details Grid -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="{StaticResource StandardBorderThickness}"
                        CornerRadius="{StaticResource StandardCornerRadius}"
                        Padding="{StaticResource Medium}"
                        Margin="{StaticResource Small}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" MinWidth="150" />
                            <ColumnDefinition Width="*" MinWidth="200" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="Auto" MinWidth="150" />
                            <ColumnDefinition Width="*" MinWidth="200" />
                        </Grid.ColumnDefinitions>

                        <!-- Row 1: Driver Commission, Vehicle Loaded By -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Driver Commission"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   VerticalAlignment="Center"
                                   Margin="{StaticResource ExtraSmall}" />
                        <TextBox Grid.Row="0" Grid.Column="1"
                                 Text="{Binding DriverCommission, UpdateSourceTrigger=PropertyChanged}"
                                 Height="{StaticResource StandardControlHeight}"
                                 Margin="{StaticResource ExtraSmall}" />

                        <TextBlock Grid.Row="0" Grid.Column="3" Text="Vehicle Loaded By"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   VerticalAlignment="Center"
                                   Margin="{StaticResource ExtraSmall}" />
                        <TextBox Grid.Row="0" Grid.Column="4"
                                 Text="{Binding VehicleLoadedBy, UpdateSourceTrigger=PropertyChanged}"
                                 Height="{StaticResource StandardControlHeight}"
                                 Margin="{StaticResource ExtraSmall}" />

                        <!-- Row 2: Fuel Quantity, Fuel Amount -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Fuel Quantity"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   VerticalAlignment="Center"
                                   Margin="{StaticResource ExtraSmall}" />
                        <TextBox Grid.Row="1" Grid.Column="1"
                                 Text="{Binding FuelQuantity, UpdateSourceTrigger=PropertyChanged}"
                                 Height="{StaticResource StandardControlHeight}"
                                 Margin="{StaticResource ExtraSmall}" />

                        <TextBlock Grid.Row="1" Grid.Column="3" Text="Fuel Amount"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   VerticalAlignment="Center"
                                   Margin="{StaticResource ExtraSmall}" />
                        <TextBox Grid.Row="1" Grid.Column="4"
                                 Text="{Binding FuelAmount, UpdateSourceTrigger=PropertyChanged}"
                                 Height="{StaticResource StandardControlHeight}"
                                 Margin="{StaticResource ExtraSmall}" />

                        <!-- Row 3: Fuel Cash, Fuel Advance -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Fuel Cash"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   VerticalAlignment="Center"
                                   Margin="{StaticResource ExtraSmall}" />
                        <TextBox Grid.Row="2" Grid.Column="1"
                                 Text="{Binding FuelCash, UpdateSourceTrigger=PropertyChanged}"
                                 Height="{StaticResource StandardControlHeight}"
                                 Margin="{StaticResource ExtraSmall}" />

                        <TextBlock Grid.Row="2" Grid.Column="3" Text="Fuel Advance"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   VerticalAlignment="Center"
                                   Margin="{StaticResource ExtraSmall}" />
                        <TextBox Grid.Row="2" Grid.Column="4"
                                 Text="{Binding FuelAdvance, UpdateSourceTrigger=PropertyChanged}"
                                 Height="{StaticResource StandardControlHeight}"
                                 Margin="{StaticResource ExtraSmall}" />

                        <!-- Row 4: Cash Advance, Payment Location -->
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Cash Advance"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   VerticalAlignment="Center"
                                   Margin="{StaticResource ExtraSmall}" />
                        <TextBox Grid.Row="3" Grid.Column="1"
                                 Text="{Binding CashAdvance, UpdateSourceTrigger=PropertyChanged}"
                                 Height="{StaticResource StandardControlHeight}"
                                 Margin="{StaticResource ExtraSmall}" />

                        <TextBlock Grid.Row="3" Grid.Column="3" Text="Payment Location"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   VerticalAlignment="Center"
                                   Margin="{StaticResource ExtraSmall}" />
                        <ComboBox Grid.Row="3" Grid.Column="4"
                                  ItemsSource="{Binding PaymentLocations}"
                                  SelectedValuePath="Id"
                                  DisplayMemberPath="PaymentLocationName"
                                  SelectedValue="{Binding PaymentLocationId}"
                                  Height="{StaticResource StandardControlHeight}"
                                  Margin="{StaticResource ExtraSmall}"
                                  IsEditable="True"
                                  IsTextSearchEnabled="True"
                                  TextSearch.TextPath="PaymentLocationName" />

                        <!-- Row 5: Other Advance, Other Advance Date -->
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Other Advance"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   VerticalAlignment="Center"
                                   Margin="{StaticResource ExtraSmall}" />
                        <TextBox Grid.Row="4" Grid.Column="1"
                                 Text="{Binding OtherAdvance, UpdateSourceTrigger=PropertyChanged}"
                                 Height="{StaticResource StandardControlHeight}"
                                 Margin="{StaticResource ExtraSmall}" />

                        <TextBlock Grid.Row="4" Grid.Column="3" Text="Other Advance Date"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   VerticalAlignment="Center"
                                   Margin="{StaticResource ExtraSmall}" />
                        <DatePicker Grid.Row="4" Grid.Column="4"
                                    SelectedDate="{Binding OtherAdvanceDate}"
                                    Height="{StaticResource StandardControlHeight}"
                                    Margin="{StaticResource ExtraSmall}" />
                    </Grid>
                </Border>

                <!-- Driver & Owner Info Grid -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="{StaticResource StandardBorderThickness}"
                        CornerRadius="{StaticResource StandardCornerRadius}"
                        Padding="{StaticResource Medium}"
                        Margin="{StaticResource Small}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" MinWidth="150" />
                            <ColumnDefinition Width="*" MinWidth="200" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="Auto" MinWidth="150" />
                            <ColumnDefinition Width="*" MinWidth="200" />
                        </Grid.ColumnDefinitions>

                        <!-- Row 1: Driver, Driver Mobile -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Driver"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   VerticalAlignment="Center"
                                   Margin="{StaticResource ExtraSmall}" />
                        <TextBox Grid.Row="0" Grid.Column="1"
                                 Text="{Binding Driver, UpdateSourceTrigger=PropertyChanged}"
                                 Height="{StaticResource StandardControlHeight}"
                                 Margin="{StaticResource ExtraSmall}" />

                        <TextBlock Grid.Row="0" Grid.Column="3" Text="Driver Mobile"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   VerticalAlignment="Center"
                                   Margin="{StaticResource ExtraSmall}" />
                        <TextBox Grid.Row="0" Grid.Column="4"
                                 Text="{Binding DriverMobile, UpdateSourceTrigger=PropertyChanged}"
                                 Height="{StaticResource StandardControlHeight}"
                                 Margin="{StaticResource ExtraSmall}" />

                        <!-- Row 2: Driving Licence Number, Owner Mobile -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Driving Licence"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   VerticalAlignment="Center"
                                   Margin="{StaticResource ExtraSmall}" />
                        <TextBox Grid.Row="1" Grid.Column="1"
                                 Text="{Binding DrivingLicenceNumber, UpdateSourceTrigger=PropertyChanged}"
                                 Height="{StaticResource StandardControlHeight}"
                                 Margin="{StaticResource ExtraSmall}" />

                        <TextBlock Grid.Row="1" Grid.Column="3" Text="Owner Mobile"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   VerticalAlignment="Center"
                                   Margin="{StaticResource ExtraSmall}" />
                        <TextBox Grid.Row="1" Grid.Column="4"
                                 Text="{Binding OwnerMobile, UpdateSourceTrigger=PropertyChanged}"
                                 Height="{StaticResource StandardControlHeight}"
                                 Margin="{StaticResource ExtraSmall}" />

                        <!-- Row 3: Shortage Weight, Owner Address -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Shortage Weight"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   VerticalAlignment="Center"
                                   Margin="{StaticResource ExtraSmall}" />
                        <TextBox Grid.Row="2" Grid.Column="1"
                                 Text="{Binding ShortageWeight, UpdateSourceTrigger=PropertyChanged}"
                                 Height="{StaticResource StandardControlHeight}"
                                 Margin="{StaticResource ExtraSmall}" />

                        <TextBlock Grid.Row="2" Grid.Column="3" Text="Owner Address"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   VerticalAlignment="Center"
                                   Margin="{StaticResource ExtraSmall}" />
                        <TextBox Grid.Row="2" Grid.Column="4"
                                 Text="{Binding OwnerAddress, UpdateSourceTrigger=PropertyChanged}"
                                 Height="{StaticResource StandardControlHeight}"
                                 Margin="{StaticResource ExtraSmall}" />
                    </Grid>
                </Border>

                <!-- Notes & Active -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="{StaticResource StandardBorderThickness}"
                        CornerRadius="{StaticResource StandardCornerRadius}"
                        Padding="{StaticResource Medium}"
                        Margin="{StaticResource Small}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" MinWidth="150" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Notes"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   VerticalAlignment="Top"
                                   Margin="{StaticResource ExtraSmall}" />
                        <TextBox Grid.Row="0" Grid.Column="1"
                                 Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                 Height="60"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 Margin="{StaticResource ExtraSmall}"
                                 VerticalScrollBarVisibility="Auto" />

                        <CheckBox Grid.Row="0" Grid.Column="3"
                                  IsChecked="{Binding IsActive}"
                                  VerticalAlignment="Center"
                                  Margin="{StaticResource ExtraSmall}" />
                        <TextBlock Grid.Row="0" Grid.Column="4" Text="Active"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   VerticalAlignment="Center"
                                   Margin="{StaticResource Small}" />
                    </Grid>
                </Border>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="{StaticResource Medium}">
                    <Button Content="Save"
                            Command="{Binding SaveCommand}"
                            Height="{StaticResource StandardControlHeight}"
                            Margin="{StaticResource Small}"
                            MinWidth="100" />

                    <Button Content="Cancel"
                            Command="{Binding CancelCommand}"
                            Height="{StaticResource StandardControlHeight}"
                            Margin="{StaticResource Small}"
                            MinWidth="100" />
                </StackPanel>

                <!-- Loading Indicator -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="{StaticResource StandardBorderThickness}"
                        CornerRadius="{StaticResource StandardCornerRadius}"
                        Padding="{StaticResource Medium}"
                        Margin="{StaticResource Small}"
                        Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center">
                        <ProgressBar Height="{StaticResource StandardControlHeight}"
                                   IsIndeterminate="True"
                                   Foreground="{DynamicResource PrimaryBrush}"
                                   Margin="{StaticResource Small}" />
                        <TextBlock Text="{Binding BusyMessage}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
