<UserControl x:Class="veteran_logistic.Transactions.LoadingRegisters.Views.LoadingRegistersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:veteran_logistic.Converters"
             mc:Ignorable="d">
    <UserControl.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
    </UserControl.Resources>
    <Grid Background="{DynamicResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="{StaticResource StandardBorderThickness}"
                Padding="{StaticResource Medium}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Loading Registers"
                           Style="{StaticResource HeadingTextBlockStyle}"
                           VerticalAlignment="Center" />

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <!-- Back Button -->
                    <Button Height="{StaticResource StandardControlHeight}"
                            Command="{Binding GoBackCommand}"
                            IsEnabled="{Binding CanGoBack}"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Go Back"
                            VerticalAlignment="Center"
                            Margin="{StaticResource Small}">
                        <Viewbox Width="16" Height="16">
                            <Path Data="{StaticResource BackIconGeometry}"
                                  Fill="{DynamicResource TextPrimaryBrush}" />
                        </Viewbox>
                    </Button>

                    <!-- Search -->
                    <TextBox Height="{StaticResource StandardControlHeight}"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Margin="{StaticResource Small}"
                             VerticalAlignment="Center">
                        <TextBox.Style>
                            <Style BasedOn="{StaticResource BaseTextBoxStyle}" TargetType="TextBox">
                                <Setter Property="Padding" Value="{StaticResource Small}" />
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <!-- Add Loading Register Button -->
                    <Button Height="{StaticResource StandardControlHeight}"
                            Command="{Binding AddLoadingRegisterCommand}"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Add Loading Register"
                            VerticalAlignment="Center"
                            Margin="{StaticResource Small}">
                        <TextBlock Text="Add Loading Register"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>

                    <!-- Edit Loading Register Button -->
                    <Button Height="{StaticResource StandardControlHeight}"
                            Command="{Binding EditLoadingRegisterCommand}"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Edit Loading Register"
                            VerticalAlignment="Center"
                            Margin="{StaticResource Small}">
                        <TextBlock Text="Edit Loading Register"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>

                    <!-- Activate Loading Register Button -->
                    <Button Height="{StaticResource StandardControlHeight}"
                            Command="{Binding ActivateLoadingRegisterCommand}"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Activate Loading Register"
                            VerticalAlignment="Center"
                            Margin="{StaticResource Small}">
                        <TextBlock Text="Activate"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>

                    <!-- Deactivate Loading Register Button -->
                    <Button Height="{StaticResource StandardControlHeight}"
                            Command="{Binding DeactivateLoadingRegisterCommand}"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Deactivate Loading Register"
                            VerticalAlignment="Center"
                            Margin="{StaticResource Small}">
                        <TextBlock Text="Deactivate"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>

                    <!-- Delete Loading Register Button -->
                    <Button Height="{StaticResource StandardControlHeight}"
                            Command="{Binding DeleteLoadingRegisterCommand}"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Delete Loading Register"
                            VerticalAlignment="Center"
                            Margin="{StaticResource Small}">
                        <TextBlock Text="Delete Loading Register"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>

                    <!-- Refresh Button -->
                    <Button Height="{StaticResource StandardControlHeight}"
                            Command="{Binding RefreshCommand}"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Refresh"
                            VerticalAlignment="Center"
                            Margin="{StaticResource Small}">
                        <TextBlock Text="Refresh"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Loading Indicator -->
        <Border Grid.Row="1"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="{StaticResource StandardBorderThickness}"
                Padding="{StaticResource Medium}"
                Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">
                <ProgressBar Height="{StaticResource StandardControlHeight}"
                           IsIndeterminate="True"
                           Foreground="{DynamicResource PrimaryBrush}"
                           Margin="{StaticResource Small}" />
                <TextBlock Text="{Binding BusyMessage}"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Validation Error -->
        <Border Grid.Row="2"
                Background="{DynamicResource ErrorBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="{StaticResource StandardBorderThickness}"
                Padding="{StaticResource Medium}"
                Visibility="{Binding ValidationError, Converter={StaticResource StringToVisibilityConverter}}"
                Margin="{StaticResource Small}">
            <TextBlock Text="{Binding ValidationError}"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{DynamicResource OnErrorBrush}"
                       TextWrapping="Wrap" />
        </Border>

        <!-- DataGrid -->
        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding LoadingRegisters}"
                  SelectedItem="{Binding SelectedLoadingRegister}"
                  IsReadOnly="True"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserReorderColumns="False"
                  SelectionMode="Single"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  Background="{DynamicResource BackgroundBrush}"
                  BorderThickness="0"
                  RowBackground="{DynamicResource SurfaceBrush}"
                  AlternatingRowBackground="{DynamicResource SurfaceBrush}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Challan No."
                                    Binding="{Binding ChallanNumber}"
                                    Width="Auto" />

                <DataGridTextColumn Header="Loading Date"
                                    Binding="{Binding LoadingDate, StringFormat=dd-MM-yyyy}"
                                    Width="Auto" />

                <DataGridTextColumn Header="TP Number"
                                    Binding="{Binding TPNumber}"
                                    Width="Auto" />

                <DataGridTextColumn Header="Vehicle No."
                                    Binding="{Binding VehicleNumber}"
                                    Width="Auto" />

                <DataGridTextColumn Header="Consignor"
                                    Binding="{Binding ConsignorName}"
                                    Width="*" />

                <DataGridTextColumn Header="Consignee"
                                    Binding="{Binding ConsigneeName}"
                                    Width="*" />

                <DataGridTextColumn Header="Source"
                                    Binding="{Binding SourceName}"
                                    Width="Auto" />

                <DataGridTextColumn Header="Destination"
                                    Binding="{Binding DestinationName}"
                                    Width="Auto" />

                <DataGridTextColumn Header="Material"
                                    Binding="{Binding MaterialName}"
                                    Width="Auto" />

                <DataGridTextColumn Header="Driver"
                                    Binding="{Binding Driver}"
                                    Width="Auto" />

                <DataGridTextColumn Header="Loading Weight"
                                    Binding="{Binding LoadingWeight}"
                                    Width="Auto" />

                <DataGridTextColumn Header="Gross Amount"
                                    Binding="{Binding GrossAmount}"
                                    Width="Auto" />

                <DataGridTextColumn Header="Active"
                                    Binding="{Binding IsActive}"
                                    Width="Auto" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
