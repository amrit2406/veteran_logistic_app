<UserControl x:Class="veteran_logistic.Transactions.LoadingRegisters.Views.AddLoadingRegisterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Background="{DynamicResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="{StaticResource StandardBorderThickness}"
                Padding="{StaticResource Medium}">
            <TextBlock Text="Add Loading Register"
                       Style="{StaticResource HeadingTextBlockStyle}"
                       VerticalAlignment="Center" />
        </Border>

        <!-- Form -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="{StaticResource Large}">
            <StackPanel HorizontalAlignment="Left">
                <!-- Validation Error -->
                <Border Background="{DynamicResource ErrorBrush}"
                        BorderBrush="{DynamicResource ErrorBrush}"
                        BorderThickness="{StaticResource StandardBorderThickness}"
                        CornerRadius="{StaticResource StandardCornerRadius}"
                        Padding="{StaticResource Small}"
                        Margin="{StaticResource Small}"
                        Visibility="{Binding ValidationError, Converter={StaticResource StringToVisibilityConverter}}">
                    <TextBlock Text="{Binding ValidationError}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{DynamicResource TextOnPrimaryBrush}"
                               TextWrapping="Wrap" />
                </Border>

                <!-- Basic Information Section -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="{StaticResource StandardBorderThickness}"
                        CornerRadius="{StaticResource StandardCornerRadius}"
                        Padding="{StaticResource Medium}"
                        Margin="{StaticResource Small}">
                    <StackPanel>
                        <TextBlock Text="Basic Information"
                                   Style="{StaticResource SubHeadingTextBlockStyle}"
                                   Margin="{StaticResource Small}" />
                        
                        <!-- Loading Date -->
                        <StackPanel Margin="{StaticResource Small}">
                            <TextBlock Text="Loading Date"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       Margin="{StaticResource ExtraSmall}" />
                            <DatePicker SelectedDate="{Binding LoadingDate}"
                                        Height="{StaticResource StandardControlHeight}" />
                        </StackPanel>

                        <!-- TP Number -->
                        <StackPanel Margin="{StaticResource Small}">
                            <TextBlock Text="TP Number"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       Margin="{StaticResource ExtraSmall}" />
                            <TextBox Text="{Binding TPNumber, UpdateSourceTrigger=PropertyChanged}"
                                     Height="{StaticResource StandardControlHeight}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Consignor/Consignee Section -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="{StaticResource StandardBorderThickness}"
                        CornerRadius="{StaticResource StandardCornerRadius}"
                        Padding="{StaticResource Medium}"
                        Margin="{StaticResource Small}">
                    <StackPanel>
                        <TextBlock Text="Consignor / Consignee"
                                   Style="{StaticResource SubHeadingTextBlockStyle}"
                                   Margin="{StaticResource Small}" />
                        
                        <!-- Consignor -->
                        <StackPanel Margin="{StaticResource Small}">
                            <TextBlock Text="Consignor"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       Margin="{StaticResource ExtraSmall}" />
                            <TextBox Text="{Binding ConsignorId, UpdateSourceTrigger=PropertyChanged}"
                                     Height="{StaticResource StandardControlHeight}" />
                        </StackPanel>

                        <!-- Consignee -->
                        <StackPanel Margin="{StaticResource Small}">
                            <TextBlock Text="Consignee"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       Margin="{StaticResource ExtraSmall}" />
                            <TextBox Text="{Binding ConsigneeId, UpdateSourceTrigger=PropertyChanged}"
                                     Height="{StaticResource StandardControlHeight}" />
                        </StackPanel>

                        <!-- Source -->
                        <StackPanel Margin="{StaticResource Small}">
                            <TextBlock Text="Source"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       Margin="{StaticResource ExtraSmall}" />
                            <TextBox Text="{Binding SourceId, UpdateSourceTrigger=PropertyChanged}"
                                     Height="{StaticResource StandardControlHeight}" />
                        </StackPanel>

                        <!-- Destination -->
                        <StackPanel Margin="{StaticResource Small}">
                            <TextBlock Text="Destination"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       Margin="{StaticResource ExtraSmall}" />
                            <TextBox Text="{Binding DestinationId, UpdateSourceTrigger=PropertyChanged}"
                                     Height="{StaticResource StandardControlHeight}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Transport Information Section -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="{StaticResource StandardBorderThickness}"
                        CornerRadius="{StaticResource StandardCornerRadius}"
                        Padding="{StaticResource Medium}"
                        Margin="{StaticResource Small}">
                    <StackPanel>
                        <TextBlock Text="Transport Information"
                                   Style="{StaticResource SubHeadingTextBlockStyle}"
                                   Margin="{StaticResource Small}" />
                        
                        <!-- Vehicle -->
                        <StackPanel Margin="{StaticResource Small}">
                            <TextBlock Text="Vehicle"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       Margin="{StaticResource ExtraSmall}" />
                            <TextBox Text="{Binding VehicleId, UpdateSourceTrigger=PropertyChanged}"
                                     Height="{StaticResource StandardControlHeight}" />
                        </StackPanel>

                        <!-- Vehicle Type -->
                        <StackPanel Margin="{StaticResource Small}">
                            <TextBlock Text="Vehicle Type"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       Margin="{StaticResource ExtraSmall}" />
                            <TextBox Text="{Binding VehicleType, UpdateSourceTrigger=PropertyChanged}"
                                     Height="{StaticResource StandardControlHeight}" />
                        </StackPanel>

                        <!-- Union/Vendor -->
                        <StackPanel Margin="{StaticResource Small}">
                            <TextBlock Text="Union/Vendor"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       Margin="{StaticResource ExtraSmall}" />
                            <TextBox Text="{Binding UnionVendorId, UpdateSourceTrigger=PropertyChanged}"
                                     Height="{StaticResource StandardControlHeight}" />
                        </StackPanel>

                        <!-- Driver Commission -->
                        <StackPanel Margin="{StaticResource Small}">
                            <TextBlock Text="Driver Commission"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       Margin="{StaticResource ExtraSmall}" />
                            <TextBox Text="{Binding DriverCommission, UpdateSourceTrigger=PropertyChanged}"
                                     Height="{StaticResource StandardControlHeight}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Weight Information Section -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="{StaticResource StandardBorderThickness}"
                        CornerRadius="{StaticResource StandardCornerRadius}"
                        Padding="{StaticResource Medium}"
                        Margin="{StaticResource Small}">
                    <StackPanel>
                        <TextBlock Text="Weight Information"
                                   Style="{StaticResource SubHeadingTextBlockStyle}"
                                   Margin="{StaticResource Small}" />
                        
                        <!-- Gross Weight -->
                        <StackPanel Margin="{StaticResource Small}">
                            <TextBlock Text="Gross Weight"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       Margin="{StaticResource ExtraSmall}" />
                            <TextBox Text="{Binding GrossWeight, UpdateSourceTrigger=PropertyChanged}"
                                     Height="{StaticResource StandardControlHeight}" />
                        </StackPanel>

                        <!-- Tare Weight -->
                        <StackPanel Margin="{StaticResource Small}">
                            <TextBlock Text="Tare Weight"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       Margin="{StaticResource ExtraSmall}" />
                            <TextBox Text="{Binding TareWeight, UpdateSourceTrigger=PropertyChanged}"
                                     Height="{StaticResource StandardControlHeight}" />
                        </StackPanel>

                        <!-- Loading Weight (Calculated) -->
                        <StackPanel Margin="{StaticResource Small}">
                            <TextBlock Text="Loading Weight (Calculated)"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       Margin="{StaticResource ExtraSmall}" />
                            <TextBox Text="{Binding LoadingWeight}"
                                     IsReadOnly="True"
                                     Height="{StaticResource StandardControlHeight}" />
                        </StackPanel>

                        <!-- Material -->
                        <StackPanel Margin="{StaticResource Small}">
                            <TextBlock Text="Material"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       Margin="{StaticResource ExtraSmall}" />
                            <TextBox Text="{Binding MaterialId, UpdateSourceTrigger=PropertyChanged}"
                                     Height="{StaticResource StandardControlHeight}" />
                        </StackPanel>

                        <!-- Rate -->
                        <StackPanel Margin="{StaticResource Small}">
                            <TextBlock Text="Rate"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       Margin="{StaticResource ExtraSmall}" />
                            <TextBox Text="{Binding Rate, UpdateSourceTrigger=PropertyChanged}"
                                     Height="{StaticResource StandardControlHeight}" />
                        </StackPanel>

                        <!-- Gross Amount (Calculated) -->
                        <StackPanel Margin="{StaticResource Small}">
                            <TextBlock Text="Gross Amount (Calculated)"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       Margin="{StaticResource ExtraSmall}" />
                            <TextBox Text="{Binding GrossAmount}"
                                     IsReadOnly="True"
                                     Height="{StaticResource StandardControlHeight}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Vehicle Loading Section -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="{StaticResource StandardBorderThickness}"
                        CornerRadius="{StaticResource StandardCornerRadius}"
                        Padding="{StaticResource Medium}"
                        Margin="{StaticResource Small}">
                    <StackPanel>
                        <TextBlock Text="Vehicle Loading"
                                   Style="{StaticResource SubHeadingTextBlockStyle}"
                                   Margin="{StaticResource Small}" />
                        
                        <!-- Vehicle Loaded By -->
                        <StackPanel Margin="{StaticResource Small}">
                            <TextBlock Text="Vehicle Loaded By"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       Margin="{StaticResource ExtraSmall}" />
                            <TextBox Text="{Binding VehicleLoadedBy, UpdateSourceTrigger=PropertyChanged}"
                                     Height="{StaticResource StandardControlHeight}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Fuel Information Section -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="{StaticResource StandardBorderThickness}"
                        CornerRadius="{StaticResource StandardCornerRadius}"
                        Padding="{StaticResource Medium}"
                        Margin="{StaticResource Small}">
                    <StackPanel>
                        <TextBlock Text="Fuel Information"
                                   Style="{StaticResource SubHeadingTextBlockStyle}"
                                   Margin="{StaticResource Small}" />
                        
                        <!-- Fuel Quantity -->
                        <StackPanel Margin="{StaticResource Small}">
                            <TextBlock Text="Fuel Quantity"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       Margin="{StaticResource ExtraSmall}" />
                            <TextBox Text="{Binding FuelQuantity, UpdateSourceTrigger=PropertyChanged}"
                                     Height="{StaticResource StandardControlHeight}" />
                        </StackPanel>

                        <!-- Fuel Amount -->
                        <StackPanel Margin="{StaticResource Small}">
                            <TextBlock Text="Fuel Amount"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       Margin="{StaticResource ExtraSmall}" />
                            <TextBox Text="{Binding FuelAmount, UpdateSourceTrigger=PropertyChanged}"
                                     Height="{StaticResource StandardControlHeight}" />
                        </StackPanel>

                        <!-- Fuel Cash -->
                        <StackPanel Margin="{StaticResource Small}">
                            <TextBlock Text="Fuel Cash"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       Margin="{StaticResource ExtraSmall}" />
                            <TextBox Text="{Binding FuelCash, UpdateSourceTrigger=PropertyChanged}"
                                     Height="{StaticResource StandardControlHeight}" />
                        </StackPanel>

                        <!-- Fuel Advance -->
                        <StackPanel Margin="{StaticResource Small}">
                            <TextBlock Text="Fuel Advance"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       Margin="{StaticResource ExtraSmall}" />
                            <TextBox Text="{Binding FuelAdvance, UpdateSourceTrigger=PropertyChanged}"
                                     Height="{StaticResource StandardControlHeight}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Shortage Section -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="{StaticResource StandardBorderThickness}"
                        CornerRadius="{StaticResource StandardCornerRadius}"
                        Padding="{StaticResource Medium}"
                        Margin="{StaticResource Small}">
                    <StackPanel>
                        <TextBlock Text="Shortage"
                                   Style="{StaticResource SubHeadingTextBlockStyle}"
                                   Margin="{StaticResource Small}" />
                        
                        <!-- Shortage Weight -->
                        <StackPanel Margin="{StaticResource Small}">
                            <TextBlock Text="Shortage Weight"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       Margin="{StaticResource ExtraSmall}" />
                            <TextBox Text="{Binding ShortageWeight, UpdateSourceTrigger=PropertyChanged}"
                                     Height="{StaticResource StandardControlHeight}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Advance Information Section -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="{StaticResource StandardBorderThickness}"
                        CornerRadius="{StaticResource StandardCornerRadius}"
                        Padding="{StaticResource Medium}"
                        Margin="{StaticResource Small}">
                    <StackPanel>
                        <TextBlock Text="Advance Information"
                                   Style="{StaticResource SubHeadingTextBlockStyle}"
                                   Margin="{StaticResource Small}" />
                        
                        <!-- Cash Advance -->
                        <StackPanel Margin="{StaticResource Small}">
                            <TextBlock Text="Cash Advance"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       Margin="{StaticResource ExtraSmall}" />
                            <TextBox Text="{Binding CashAdvance, UpdateSourceTrigger=PropertyChanged}"
                                     Height="{StaticResource StandardControlHeight}" />
                        </StackPanel>

                        <!-- Payment Location -->
                        <StackPanel Margin="{StaticResource Small}">
                            <TextBlock Text="Payment Location"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       Margin="{StaticResource ExtraSmall}" />
                            <TextBox Text="{Binding PaymentLocationId, UpdateSourceTrigger=PropertyChanged}"
                                     Height="{StaticResource StandardControlHeight}" />
                        </StackPanel>

                        <!-- Other Advance -->
                        <StackPanel Margin="{StaticResource Small}">
                            <TextBlock Text="Other Advance"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       Margin="{StaticResource ExtraSmall}" />
                            <TextBox Text="{Binding OtherAdvance, UpdateSourceTrigger=PropertyChanged}"
                                     Height="{StaticResource StandardControlHeight}" />
                        </StackPanel>

                        <!-- Other Advance Date -->
                        <StackPanel Margin="{StaticResource Small}">
                            <TextBlock Text="Other Advance Date"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       Margin="{StaticResource ExtraSmall}" />
                            <DatePicker SelectedDate="{Binding OtherAdvanceDate}"
                                        Height="{StaticResource StandardControlHeight}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Third Party Section -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="{StaticResource StandardBorderThickness}"
                        CornerRadius="{StaticResource StandardCornerRadius}"
                        Padding="{StaticResource Medium}"
                        Margin="{StaticResource Small}">
                    <StackPanel>
                        <TextBlock Text="Third Party"
                                   Style="{StaticResource SubHeadingTextBlockStyle}"
                                   Margin="{StaticResource Small}" />
                        
                        <!-- Third Party -->
                        <StackPanel Margin="{StaticResource Small}">
                            <TextBlock Text="Third Party"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       Margin="{StaticResource ExtraSmall}" />
                            <TextBox Text="{Binding ThirdParty, UpdateSourceTrigger=PropertyChanged}"
                                     Height="{StaticResource StandardControlHeight}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Owner Information Section -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="{StaticResource StandardBorderThickness}"
                        CornerRadius="{StaticResource StandardCornerRadius}"
                        Padding="{StaticResource Medium}"
                        Margin="{StaticResource Small}">
                    <StackPanel>
                        <TextBlock Text="Owner Information"
                                   Style="{StaticResource SubHeadingTextBlockStyle}"
                                   Margin="{StaticResource Small}" />
                        
                        <!-- Owner -->
                        <StackPanel Margin="{StaticResource Small}">
                            <TextBlock Text="Owner"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       Margin="{StaticResource ExtraSmall}" />
                            <TextBox Text="{Binding OwnerId, UpdateSourceTrigger=PropertyChanged}"
                                     Height="{StaticResource StandardControlHeight}" />
                        </StackPanel>

                        <!-- Owner Mobile -->
                        <StackPanel Margin="{StaticResource Small}">
                            <TextBlock Text="Owner Mobile"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       Margin="{StaticResource ExtraSmall}" />
                            <TextBox Text="{Binding OwnerMobile, UpdateSourceTrigger=PropertyChanged}"
                                     Height="{StaticResource StandardControlHeight}" />
                        </StackPanel>

                        <!-- Owner Address -->
                        <StackPanel Margin="{StaticResource Small}">
                            <TextBlock Text="Owner Address"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       Margin="{StaticResource ExtraSmall}" />
                            <TextBox Text="{Binding OwnerAddress, UpdateSourceTrigger=PropertyChanged}"
                                     Height="{StaticResource StandardControlHeight}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Driver Information Section -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="{StaticResource StandardBorderThickness}"
                        CornerRadius="{StaticResource StandardCornerRadius}"
                        Padding="{StaticResource Medium}"
                        Margin="{StaticResource Small}">
                    <StackPanel>
                        <TextBlock Text="Driver Information"
                                   Style="{StaticResource SubHeadingTextBlockStyle}"
                                   Margin="{StaticResource Small}" />
                        
                        <!-- Driver -->
                        <StackPanel Margin="{StaticResource Small}">
                            <TextBlock Text="Driver"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       Margin="{StaticResource ExtraSmall}" />
                            <TextBox Text="{Binding Driver, UpdateSourceTrigger=PropertyChanged}"
                                     Height="{StaticResource StandardControlHeight}" />
                        </StackPanel>

                        <!-- Driving Licence Number -->
                        <StackPanel Margin="{StaticResource Small}">
                            <TextBlock Text="Driving Licence Number"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       Margin="{StaticResource ExtraSmall}" />
                            <TextBox Text="{Binding DrivingLicenceNumber, UpdateSourceTrigger=PropertyChanged}"
                                     Height="{StaticResource StandardControlHeight}" />
                        </StackPanel>

                        <!-- Driver Mobile -->
                        <StackPanel Margin="{StaticResource Small}">
                            <TextBlock Text="Driver Mobile"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       Margin="{StaticResource ExtraSmall}" />
                            <TextBox Text="{Binding DriverMobile, UpdateSourceTrigger=PropertyChanged}"
                                     Height="{StaticResource StandardControlHeight}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Additional Information Section -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="{StaticResource StandardBorderThickness}"
                        CornerRadius="{StaticResource StandardCornerRadius}"
                        Padding="{StaticResource Medium}"
                        Margin="{StaticResource Small}">
                    <StackPanel>
                        <TextBlock Text="Additional Information"
                                   Style="{StaticResource SubHeadingTextBlockStyle}"
                                   Margin="{StaticResource Small}" />
                        
                        <!-- Notes -->
                        <StackPanel Margin="{StaticResource Small}">
                            <TextBlock Text="Notes"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       Margin="{StaticResource ExtraSmall}" />
                            <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                     Height="80"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True" />
                        </StackPanel>

                        <!-- Active -->
                        <StackPanel Margin="{StaticResource Small}"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <CheckBox IsChecked="{Binding IsActive}"
                                      VerticalAlignment="Center"
                                      Margin="{StaticResource ExtraSmall}" />
                            <TextBlock Text="Active"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       VerticalAlignment="Center"
                                       Margin="{StaticResource Small}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="{StaticResource Medium}">
                    <Button Content="Save"
                            Command="{Binding SaveCommand}"
                            Height="{StaticResource StandardControlHeight}"
                            Margin="{StaticResource Small}" />

                    <Button Content="Cancel"
                            Command="{Binding CancelCommand}"
                            Height="{StaticResource StandardControlHeight}"
                            Margin="{StaticResource Small}" />
                </StackPanel>

                <!-- Loading Indicator -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="{StaticResource StandardBorderThickness}"
                        CornerRadius="{StaticResource StandardCornerRadius}"
                        Padding="{StaticResource Medium}"
                        Margin="{StaticResource Small}"
                        Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center">
                        <ProgressBar Height="{StaticResource StandardControlHeight}"
                                   IsIndeterminate="True"
                                   Foreground="{DynamicResource PrimaryBrush}"
                                   Margin="{StaticResource Small}" />
                        <TextBlock Text="{Binding BusyMessage}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
