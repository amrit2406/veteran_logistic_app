<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===================================================================================== -->
    <!-- Color Palette                                                                         -->
    <!-- Defines the raw color values for the theme. These should not be used directly in      -->
    <!-- styles; use the brushes defined in Brushes.xaml instead.                              -->
    <!-- ===================================================================================== -->

    <!-- Brand & Accent Colors -->
    <Color x:Key="PrimaryColor">#0F4C81</Color>
    <Color x:Key="PrimaryDarkColor">#0A3356</Color>
    <Color x:Key="PrimaryLightColor">#D6E3EE</Color>
    <Color x:Key="SecondaryColor">#6C757D</Color>
    <Color x:Key="AccentColor">#F39C12</Color>

    <!-- Semantic Colors -->
    <Color x:Key="SuccessColor">#198754</Color>
    <Color x:Key="WarningColor">#FFC107</Color>
    <Color x:Key="ErrorColor">#DC3545</Color>
    <Color x:Key="InformationColor">#0DCAF0</Color>

    <!-- UI Surface Colors -->
    <Color x:Key="BackgroundColor">#F5F7FA</Color>
    <Color x:Key="SurfaceColor">#FFFFFF</Color>
    <Color x:Key="BorderColor">#DEE2E6</Color>
    <Color x:Key="DividerColor">#E9ECEF</Color>

    <!-- Text Colors -->
    <Color x:Key="TextPrimaryColor">#212529</Color>
    <Color x:Key="TextSecondaryColor">#6C757D</Color>
    <Color x:Key="TextDisabledColor">#ADB5BD</Color>
    <Color x:Key="TextOnPrimaryColor">#FFFFFF</Color>

    <!-- Interaction State Colors -->
    <Color x:Key="SelectionColor">#D6E3EE</Color>
    <Color x:Key="HoverColor">#F8F9FA</Color>
    <Color x:Key="PressedColor">#E9ECEF</Color>
    <Color x:Key="FocusColor">#86B7FE</Color>

</ResourceDictionary>