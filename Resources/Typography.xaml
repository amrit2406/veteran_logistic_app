<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <FontFamily x:Key="DefaultFontFamily">Segoe UI</FontFamily>
    <FontFamily x:Key="HeadingFontFamily">Segoe UI Semibold</FontFamily>
    <sys:Double x:Key="SmallFontSize">12</sys:Double>
    <sys:Double x:Key="NormalFontSize">14</sys:Double>
    <sys:Double x:Key="MediumFontSize">16</sys:Double>
    <sys:Double x:Key="LargeFontSize">20</sys:Double>
    <sys:Double x:Key="ExtraLargeFontSize">24</sys:Double>
    <FontWeight x:Key="LightFontWeight">Light</FontWeight>
    <FontWeight x:Key="NormalFontWeight">Normal</FontWeight>
    <FontWeight x:Key="SemiBoldFontWeight">SemiBold</FontWeight>
    <FontWeight x:Key="BoldFontWeight">Bold</FontWeight>
</ResourceDictionary>
