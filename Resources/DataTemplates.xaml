<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:vm="clr-namespace:veteran_logistic.Shell"
                    xmlns:views="clr-namespace:veteran_logistic.Shell"
                    xmlns:authVm="clr-namespace:veteran_logistic.Authentication.ViewModels"
                    xmlns:authViews="clr-namespace:veteran_logistic.Authentication.Views"
                    xmlns:fyVm="clr-namespace:veteran_logistic.FinancialYear.ViewModels"
                    xmlns:fyViews="clr-namespace:veteran_logistic.FinancialYear.Views"
                    xmlns:adminUsersVm="clr-namespace:veteran_logistic.Administration.Users.ViewModels"
                    xmlns:adminUsersViews="clr-namespace:veteran_logistic.Administration.Users.Views"
                    xmlns:adminRolesVm="clr-namespace:veteran_logistic.Administration.Roles.ViewModels"
                    xmlns:adminRolesViews="clr-namespace:veteran_logistic.Administration.Roles.Views">
  <DataTemplate DataType="{x:Type vm:ShellViewModel}">
    <views:ShellView />
  </DataTemplate>

  <DataTemplate DataType="{x:Type authVm:LoginViewModel}">
    <authViews:LoginView />
  </DataTemplate>

  <DataTemplate DataType="{x:Type fyVm:FinancialYearSelectionViewModel}">
    <fyViews:FinancialYearSelectionView />
  </DataTemplate>

  <DataTemplate DataType="{x:Type adminUsersVm:UsersViewModel}">
    <adminUsersViews:UsersView />
  </DataTemplate>

  <DataTemplate DataType="{x:Type adminUsersVm:AddUserViewModel}">
    <adminUsersViews:AddUserView />
  </DataTemplate>

  <DataTemplate DataType="{x:Type adminUsersVm:EditUserViewModel}">
    <adminUsersViews:EditUserView />
  </DataTemplate>

  <DataTemplate DataType="{x:Type adminUsersVm:ResetPasswordViewModel}">
    <adminUsersViews:ResetPasswordView />
  </DataTemplate>

  <DataTemplate DataType="{x:Type adminRolesVm:RolesViewModel}">
    <adminRolesViews:RolesView />
  </DataTemplate>

  <DataTemplate DataType="{x:Type vm:PlaceholderViewModel}">
    <Border Background="{DynamicResource BackgroundBrush}" Padding="{StaticResource ExtraLarge}">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="1"
                Width="640"
                Background="{DynamicResource SurfaceBrush}"
                Padding="{StaticResource Large}"
                CornerRadius="{StaticResource StandardCornerRadius}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="{StaticResource StandardBorderThickness}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
          <StackPanel>
            <TextBlock Text="{Binding Title}"
                       Style="{StaticResource HeadingTextBlockStyle}"
                       Foreground="{DynamicResource PrimaryBrush}"
                       HorizontalAlignment="Center" />
            <TextBlock Text="{Binding Subtitle}"
                       Style="{StaticResource SubHeadingTextBlockStyle}"
                       Margin="0,8,0,0"
                       HorizontalAlignment="Center" />
            <TextBlock Text="{Binding Message}"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Margin="0,12,0,0"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center" />
          </StackPanel>
        </Border>
      </Grid>
    </Border>
  </DataTemplate>
</ResourceDictionary>
