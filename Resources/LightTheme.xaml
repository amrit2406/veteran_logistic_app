<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===================================================================================== -->
    <!-- Light Theme                                                                           -->
    <!-- This is the main entry point for the Light theme. It merges all the necessary         -->
    <!-- resource dictionaries that constitute the design system.                              -->
    <!-- ===================================================================================== -->

    <ResourceDictionary.MergedDictionaries>
        <!-- 1. Foundational Resources (Order is important) -->
        <ResourceDictionary Source="/Resources/Colors.xaml" />
        <ResourceDictionary Source="/Resources/Brushes.xaml" />
        <ResourceDictionary Source="/Resources/Typography.xaml" />
        <ResourceDictionary Source="/Resources/Spacing.xaml" />
        <ResourceDictionary Source="/Resources/Icons.xaml" />

        <!-- 2. Control Styles -->
        <ResourceDictionary Source="/Resources/WindowStyles.xaml" />
        <ResourceDictionary Source="/Resources/TextBlockStyles.xaml" />
        <ResourceDictionary Source="/Resources/ButtonStyles.xaml" />
        <ResourceDictionary Source="/Resources/TextBoxStyles.xaml" />
        <ResourceDictionary Source="/Resources/ComboBoxStyles.xaml" />
        <ResourceDictionary Source="/Resources/DataGridStyles.xaml" />
        <ResourceDictionary Source="/Resources/MenuStyles.xaml" />
        <ResourceDictionary Source="/Resources/StatusBarStyles.xaml" />
        <!-- Add other control styles here: DatePicker, CheckBox, etc. -->

    </ResourceDictionary.MergedDictionaries>

</ResourceDictionary>
