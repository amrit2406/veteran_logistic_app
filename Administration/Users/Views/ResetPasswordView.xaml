<UserControl x:Class="veteran_logistic.Administration.Users.Views.ResetPasswordView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ap="clr-namespace:veteran_logistic.AttachedProperties"
             mc:Ignorable="d">
    <Grid Background="{DynamicResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="{StaticResource StandardBorderThickness}"
                Padding="{StaticResource Medium}">
            <TextBlock Text="Reset Password"
                       Style="{StaticResource HeadingTextBlockStyle}"
                       VerticalAlignment="Center" />
        </Border>

        <!-- Form -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="{StaticResource Large}">
            <StackPanel HorizontalAlignment="Left">
                <!-- Validation Error -->
                <Border Background="{DynamicResource ErrorBrush}"
                        BorderBrush="{DynamicResource ErrorBrush}"
                        BorderThickness="{StaticResource StandardBorderThickness}"
                        CornerRadius="{StaticResource StandardCornerRadius}"
                        Padding="{StaticResource Small}"
                        Margin="{StaticResource Small}"
                        Visibility="{Binding ValidationError, Converter={StaticResource StringToVisibilityConverter}}">
                    <TextBlock Text="{Binding ValidationError}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{DynamicResource TextOnPrimaryBrush}"
                               TextWrapping="Wrap" />
                </Border>

                <!-- New Password -->
                <StackPanel Margin="{StaticResource Small}">
                    <TextBlock Text="New Password"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Margin="{StaticResource ExtraSmall}" />
                    <PasswordBox ap:PasswordBoxHelper.Attach="True"
                                ap:PasswordBoxHelper.Password="{Binding NewPassword, Mode=TwoWay}"
                                Height="{StaticResource StandardControlHeight}" />
                </StackPanel>

                <!-- Confirm Password -->
                <StackPanel Margin="{StaticResource Small}">
                    <TextBlock Text="Confirm Password"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Margin="{StaticResource ExtraSmall}" />
                    <PasswordBox ap:PasswordBoxHelper.Attach="True"
                                ap:PasswordBoxHelper.Password="{Binding ConfirmPassword, Mode=TwoWay}"
                                Height="{StaticResource StandardControlHeight}" />
                </StackPanel>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="{StaticResource Medium}">
                    <Button Content="Save"
                            Command="{Binding SaveCommand}"
                            Height="{StaticResource StandardControlHeight}"
                            Margin="{StaticResource Small}" />

                    <Button Content="Cancel"
                            Command="{Binding CancelCommand}"
                            Height="{StaticResource StandardControlHeight}"
                            Margin="{StaticResource Small}" />
                </StackPanel>

                <!-- Loading Indicator -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="{StaticResource StandardBorderThickness}"
                        CornerRadius="{StaticResource StandardCornerRadius}"
                        Padding="{StaticResource Medium}"
                        Margin="{StaticResource Small}"
                        Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center">
                        <ProgressBar Height="{StaticResource StandardControlHeight}"
                                   IsIndeterminate="True"
                                   Foreground="{DynamicResource PrimaryBrush}"
                                   Margin="{StaticResource Small}" />
                        <TextBlock Text="{Binding BusyMessage}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
