<UserControl x:Class="veteran_logistic.Administration.Permissions.Views.PermissionMatrixView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:veteran_logistic.Converters"
             mc:Ignorable="d">
<UserControl.Resources>
    <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
</UserControl.Resources>
    <Grid Background="{DynamicResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="{StaticResource StandardBorderThickness}"
                Padding="{StaticResource Medium}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Permission Matrix"
                           Style="{StaticResource HeadingTextBlockStyle}"
                           VerticalAlignment="Center" />

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <!-- Refresh Button -->
                    <Button Height="{StaticResource StandardControlHeight}"
                            Command="{Binding RefreshCommand}"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Refresh"
                            VerticalAlignment="Center"
                            Margin="{StaticResource Small}">
                        <TextBlock Text="Refresh"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>

                    <!-- Cancel Button -->
                    <Button Height="{StaticResource StandardControlHeight}"
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Cancel"
                            VerticalAlignment="Center"
                            Margin="{StaticResource Small}">
                        <TextBlock Text="Cancel"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>

                    <!-- Save Button -->
                    <Button Height="{StaticResource StandardControlHeight}"
                            Command="{Binding SaveCommand}"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Save"
                            VerticalAlignment="Center"
                            Margin="{StaticResource Small}">
                        <TextBlock Text="Save"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Role Selector -->
        <Border Grid.Row="1"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="{StaticResource StandardBorderThickness}"
                Padding="{StaticResource Medium}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Select Role:"
                           Style="{StaticResource BodyTextBlockStyle}"
                           VerticalAlignment="Center"
                           Margin="{StaticResource Small}" />

                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding Roles}"
                          SelectedItem="{Binding SelectedRole, Mode=TwoWay}"
                          DisplayMemberPath="RoleName"
                          Height="{StaticResource StandardControlHeight}"
                          Margin="{StaticResource Small}"
                          IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}" />
            </Grid>
        </Border>

        <!-- Validation Error -->
        <Border Grid.Row="2"
                Background="{DynamicResource ErrorBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="{StaticResource StandardBorderThickness}"
                Padding="{DynamicResource Medium}"
                Visibility="{Binding ValidationError, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}"
                Margin="{StaticResource Small}">
            <TextBlock Text="{Binding ValidationError}"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{DynamicResource OnErrorBrush}"
                       TextWrapping="Wrap" />
        </Border>

        <!-- Loading Indicator -->
        <Border Grid.Row="2"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="{StaticResource StandardBorderThickness}"
                Padding="{StaticResource Medium}"
                Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"
                Margin="{StaticResource Small}">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">
                <ProgressBar Height="{StaticResource StandardControlHeight}"
                           IsIndeterminate="True"
                           Foreground="{DynamicResource PrimaryBrush}"
                           Margin="{StaticResource Small}" />
                <TextBlock Text="{Binding BusyMessage}"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Permission Matrix DataGrid -->
        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding Permissions}"
                  IsReadOnly="True"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserReorderColumns="False"
                  SelectionMode="Single"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  Background="{DynamicResource BackgroundBrush}"
                  BorderThickness="0"
                  RowBackground="{DynamicResource SurfaceBrush}"
                  AlternatingRowBackground="{DynamicResource SurfaceBrush}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Module"
                                    Binding="{Binding Module}"
                                    Width="*" />

                <DataGridTextColumn Header="Screen"
                                    Binding="{Binding Screen}"
                                    Width="*" />

                <DataGridTextColumn Header="Permission"
                                    Binding="{Binding DisplayName}"
                                    Width="2*" />

                <DataGridTextColumn Header="Description"
                                    Binding="{Binding Description}"
                                    Width="2*" />

                <DataGridTemplateColumn Header="Granted"
                                        Width="Auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsGranted, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="{Binding DataContext.SelectedRole, 
                                                        RelativeSource={RelativeSource AncestorType=UserControl}, 
                                                        Converter={StaticResource NullToBooleanConverter}}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Margin="{StaticResource Small}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
