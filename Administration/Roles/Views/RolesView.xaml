<UserControl x:Class="veteran_logistic.Administration.Roles.Views.RolesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Background="{DynamicResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="{StaticResource StandardBorderThickness}"
                Padding="{StaticResource Medium}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Roles"
                           Style="{StaticResource HeadingTextBlockStyle}"
                           VerticalAlignment="Center" />

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <!-- Search -->
                    <TextBox Height="{StaticResource StandardControlHeight}"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Margin="{StaticResource Small}"
                             VerticalAlignment="Center">
                        <TextBox.Style>
                            <Style BasedOn="{StaticResource BaseTextBoxStyle}" TargetType="TextBox">
                                <Setter Property="Padding" Value="{StaticResource Small}" />
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <!-- Add Role Button -->
                    <Button Height="{StaticResource StandardControlHeight}"
                            Command="{Binding AddRoleCommand}"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Add Role"
                            VerticalAlignment="Center"
                            Margin="{StaticResource Small}">
                        <TextBlock Text="Add Role"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>

                    <!-- Edit Role Button -->
                    <Button Height="{StaticResource StandardControlHeight}"
                            Command="{Binding EditRoleCommand}"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Edit Role"
                            VerticalAlignment="Center"
                            Margin="{StaticResource Small}">
                        <TextBlock Text="Edit Role"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>

                    <!-- Activate Role Button -->
                    <Button Height="{StaticResource StandardControlHeight}"
                            Command="{Binding ActivateRoleCommand}"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Activate Role"
                            VerticalAlignment="Center"
                            Margin="{StaticResource Small}">
                        <TextBlock Text="Activate"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>

                    <!-- Deactivate Role Button -->
                    <Button Height="{StaticResource StandardControlHeight}"
                            Command="{Binding DeactivateRoleCommand}"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Deactivate Role"
                            VerticalAlignment="Center"
                            Margin="{StaticResource Small}">
                        <TextBlock Text="Deactivate"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>

                    <!-- Delete Role Button -->
                    <Button Height="{StaticResource StandardControlHeight}"
                            Command="{Binding DeleteRoleCommand}"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Delete Role"
                            VerticalAlignment="Center"
                            Margin="{StaticResource Small}">
                        <TextBlock Text="Delete Role"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>

                    <!-- Refresh Button -->
                    <Button Height="{StaticResource StandardControlHeight}"
                            Command="{Binding RefreshCommand}"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Refresh"
                            VerticalAlignment="Center"
                            Margin="{StaticResource Small}">
                        <TextBlock Text="Refresh"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Loading Indicator -->
        <Border Grid.Row="1"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="{StaticResource StandardBorderThickness}"
                Padding="{StaticResource Medium}"
                Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">
                <ProgressBar Height="{StaticResource StandardControlHeight}"
                           IsIndeterminate="True"
                           Foreground="{DynamicResource PrimaryBrush}"
                           Margin="{StaticResource Small}" />
                <TextBlock Text="{Binding BusyMessage}"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Validation Error -->
        <Border Grid.Row="2"
                Background="{DynamicResource ErrorBrush}"
                BorderBrush="{DynamicResource ErrorBrush}"
                BorderThickness="{StaticResource StandardBorderThickness}"
                Padding="{StaticResource Medium}"
                Visibility="{Binding ValidationError, Converter={StaticResource StringToVisibilityConverter}}">
            <TextBlock Text="{Binding ValidationError}"
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{DynamicResource OnErrorBrush}"
                       TextWrapping="Wrap" />
        </Border>

        <!-- DataGrid -->
        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding Roles}"
                  SelectedItem="{Binding SelectedRole}"
                  IsReadOnly="True"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserReorderColumns="False"
                  SelectionMode="Single"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  Background="{DynamicResource BackgroundBrush}"
                  BorderThickness="0"
                  RowBackground="{DynamicResource SurfaceBrush}"
                  AlternatingRowBackground="{DynamicResource SurfaceBrush}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name"
                                    Binding="{Binding Name}"
                                    Width="*" />

                <DataGridTextColumn Header="Description"
                                    Binding="{Binding Description}"
                                    Width="*" />

                <DataGridTextColumn Header="Active"
                                    Binding="{Binding IsActive}"
                                    Width="Auto" />

                <DataGridTextColumn Header="System Role"
                                    Binding="{Binding IsSystemRole}"
                                    Width="Auto" />

                <DataGridTextColumn Header="Created Date"
                                    Binding="{Binding CreatedOn, StringFormat=yyyy-MM-dd}"
                                    Width="Auto" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
