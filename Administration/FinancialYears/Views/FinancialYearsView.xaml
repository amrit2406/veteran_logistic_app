<UserControl x:Class="veteran_logistic.Administration.FinancialYears.Views.FinancialYearsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:veteran_logistic.Converters"
             mc:Ignorable="d">
    <UserControl.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
    </UserControl.Resources>
    <Grid Background="{DynamicResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="{StaticResource StandardBorderThickness}"
                Padding="{StaticResource Medium}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Financial Years"
                           Style="{StaticResource HeadingTextBlockStyle}"
                           VerticalAlignment="Center" />

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <!-- Search (placeholder - disabled) -->
                    <TextBox Height="{StaticResource StandardControlHeight}"
                             IsEnabled="False"
                             Margin="{StaticResource Small}"
                             VerticalAlignment="Center">
                        <TextBox.Style>
                            <Style BasedOn="{StaticResource BaseTextBoxStyle}" TargetType="TextBox">
                                <Setter Property="Padding" Value="{StaticResource Small}" />
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <!-- Add Financial Year Button (placeholder - disabled) -->
                    <Button Height="{StaticResource StandardControlHeight}"
                            IsEnabled="False"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Add Financial Year"
                            VerticalAlignment="Center"
                            Margin="{StaticResource Small}">
                        <TextBlock Text="Add Financial Year"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>

                    <!-- Refresh Button -->
                    <Button Height="{StaticResource StandardControlHeight}"
                            Command="{Binding RefreshCommand}"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Refresh"
                            VerticalAlignment="Center"
                            Margin="{StaticResource Small}">
                        <TextBlock Text="Refresh"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Loading Indicator -->
        <Border Grid.Row="1"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="{StaticResource StandardBorderThickness}"
                Padding="{StaticResource Medium}"
                Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">
                <ProgressBar Height="{StaticResource StandardControlHeight}"
                           IsIndeterminate="True"
                           Foreground="{DynamicResource PrimaryBrush}"
                           Margin="{StaticResource Small}" />
                <TextBlock Text="{Binding BusyMessage}"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Validation Error -->
        <Border Grid.Row="2"
                Background="{DynamicResource ErrorBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="{StaticResource StandardBorderThickness}"
                Padding="{StaticResource Medium}"
                Visibility="{Binding ValidationError, Converter={StaticResource StringToVisibilityConverter}}"
                Margin="{StaticResource Small}">
            <TextBlock Text="{Binding ValidationError}"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{DynamicResource OnErrorBrush}"
                       TextWrapping="Wrap" />
        </Border>

        <!-- DataGrid -->
        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding FinancialYears}"
                  IsReadOnly="True"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserReorderColumns="False"
                  SelectionMode="Single"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  Background="{DynamicResource BackgroundBrush}"
                  BorderThickness="0"
                  RowBackground="{DynamicResource SurfaceBrush}"
                  AlternatingRowBackground="{DynamicResource SurfaceBrush}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name"
                                    Binding="{Binding Name}"
                                    Width="*" />

                <DataGridTextColumn Header="Start Date"
                                    Binding="{Binding StartDate, StringFormat=yyyy-MM-dd}"
                                    Width="Auto" />

                <DataGridTextColumn Header="End Date"
                                    Binding="{Binding EndDate, StringFormat=yyyy-MM-dd}"
                                    Width="Auto" />

                <DataGridTextColumn Header="Current"
                                    Binding="{Binding IsCurrent}"
                                    Width="Auto" />

                <DataGridTextColumn Header="Closed"
                                    Binding="{Binding IsClosed}"
                                    Width="Auto" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
