<UserControl x:Class="veteran_logistic.Shell.ShellView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:veteran_logistic.Shell"
             mc:Ignorable="d">
    <Grid Background="{DynamicResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="28" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1" Margin="0,0,0,43" Grid.RowSpan="2">
            <Grid Margin="{StaticResource Large}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Width="48"
                        Height="48"
                        Background="{DynamicResource PrimaryBrush}"
                        CornerRadius="{StaticResource StandardCornerRadius}"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Left">
                    <TextBlock Text="VL"
                               Foreground="{DynamicResource TextOnPrimaryBrush}"
                               FontWeight="{StaticResource BoldFontWeight}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                    <TextBlock Text="Veteran Logistics"
                               Style="{StaticResource HeadingTextBlockStyle}"
                               Margin="8,0"
                               VerticalAlignment="Center" />
                    <TextBlock Text=" | FY: 2025-2026"
                               Style="{StaticResource SubHeadingTextBlockStyle}"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <Button Width="36"
                            Height="36"
                            Style="{StaticResource IconButtonStyle}"
                            Command="{Binding GoBackCommand}"
                            IsEnabled="{Binding CanGoBack}"
                            ToolTip="Go Back"
                            Margin="0,0,8,0">
                        <Viewbox Width="16" Height="16">
                            <Path Data="{StaticResource BackIconGeometry}"
                                  Fill="{DynamicResource TextPrimaryBrush}" />
                        </Viewbox>
                    </Button>

                    <Button Width="36"
                            Height="36"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Notifications">
                        <Viewbox Width="16" Height="16">
                            <Path Data="{StaticResource BellIconGeometry}"
                                  Fill="{DynamicResource TextPrimaryBrush}" />
                        </Viewbox>
                    </Button>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="John.Doe"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center" />
                        <Button Content="Profile" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Menu Style="{StaticResource TopMenuStyle}" HorizontalAlignment="Stretch">
                <MenuItem Header="Dashboard" Style="{StaticResource TopMenuItemStyle}">
                    <MenuItem Header="Overview" />
                    <MenuItem Header="KPIs" />
                </MenuItem>
                <MenuItem Header="Masters" Style="{StaticResource TopMenuItemStyle}">
                    <MenuItem Header="Companies" Command="{Binding NavigateToCompaniesCommand}" />
                    <MenuItem Header="Customers" Command="{Binding NavigateToCustomersCommand}" />
                    <MenuItem Header="Vendors" Command="{Binding NavigateToVendorsCommand}" />
                    <MenuItem Header="Source/Destinations" Command="{Binding NavigateToSourceDestinationsCommand}" />
                    <MenuItem Header="Materials" Command="{Binding NavigateToMaterialsCommand}" />
                    <MenuItem Header="Fuel Pumps" Command="{Binding NavigateToFuelPumpsCommand}" />
                    <MenuItem Header="HSD Rates" Command="{Binding NavigateToHsdRatesCommand}" />
                    <MenuItem Header="Payment Locations" Command="{Binding NavigateToPaymentLocationsCommand}" />
                    <MenuItem Header="Vehicle Owners" Command="{Binding NavigateToVehicleOwnersCommand}" />
                    <MenuItem Header="Vehicles" Command="{Binding NavigateToVehiclesCommand}" />
                    <MenuItem Header="Vehicle Assignment" Command="{Binding NavigateToVehicleAssignmentsCommand}" />
                    <MenuItem Header="DO Rate Setup" Command="{Binding NavigateToDORatesCommand}" />
                </MenuItem>
                <MenuItem Header="Transactions" Style="{StaticResource TopMenuItemStyle}">
                    <MenuItem Header="Orders" />
                    <MenuItem Header="Shipments" />
                </MenuItem>
                <MenuItem Header="Reports" Style="{StaticResource TopMenuItemStyle}">
                    <MenuItem Header="Sales" />
                    <MenuItem Header="Inventory" />
                </MenuItem>
                <MenuItem Header="Administration" Style="{StaticResource TopMenuItemStyle}">
                    <MenuItem Header="Users" Command="{Binding NavigateToUsersCommand}" />
                    <MenuItem Header="Roles" Command="{Binding NavigateToRolesCommand}" />
                    <MenuItem Header="Permission Matrix" Command="{Binding NavigateToPermissionMatrixCommand}" />
                    <MenuItem Header="Financial Years" Command="{Binding NavigateToFinancialYearsCommand}" />
                </MenuItem>
                <MenuItem Header="Settings" Style="{StaticResource TopMenuItemStyle}" />
                <MenuItem Header="Help" Style="{StaticResource TopMenuItemStyle}" />
            </Menu>
        </Border>

        <Border Grid.Row="2" Background="{DynamicResource BackgroundBrush}" Padding="{StaticResource Large}">
            <ContentControl Content="{Binding CurrentViewModel}" />
        </Border>

        <Border Grid.Row="3"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1,1,0,0" Margin="0,0,0,-9">
            <Grid Margin="{StaticResource Medium}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Ready" Style="{StaticResource CaptionTextBlockStyle}" Margin="0,0,12,0" VerticalAlignment="Center" />
                    <TextBlock Text="FY: 2025-2026" Style="{StaticResource CaptionTextBlockStyle}" Margin="0,0,12,0" VerticalAlignment="Center" />
                    <TextBlock Text="Date: 2026-01-01" Style="{StaticResource CaptionTextBlockStyle}" VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock Text="v0.1.0" Style="{StaticResource CaptionTextBlockStyle}" Margin="0,0,12,0" VerticalAlignment="Center" />
                    <TextBlock Text="DB: Unknown" Style="{StaticResource CaptionTextBlockStyle}" Margin="0,0,12,0" VerticalAlignment="Center" />
                    <TextBlock Text="Offline" Style="{StaticResource CaptionTextBlockStyle}" VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
