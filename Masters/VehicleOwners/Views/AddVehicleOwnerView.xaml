<UserControl x:Class="veteran_logistic.Masters.VehicleOwners.Views.AddVehicleOwnerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Background="{DynamicResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="{StaticResource StandardBorderThickness}"
                Padding="{StaticResource Medium}">
            <TextBlock Text="Add Vehicle Owner"
                       Style="{StaticResource HeadingTextBlockStyle}"
                       VerticalAlignment="Center" />
        </Border>

        <!-- Form -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="{StaticResource Large}">
            <StackPanel HorizontalAlignment="Left">
                <!-- Validation Error -->
                <Border Background="{DynamicResource ErrorBrush}"
                        BorderBrush="{DynamicResource ErrorBrush}"
                        BorderThickness="{StaticResource StandardBorderThickness}"
                        CornerRadius="{StaticResource StandardCornerRadius}"
                        Padding="{StaticResource Small}"
                        Margin="{StaticResource Small}"
                        Visibility="{Binding ValidationError, Converter={StaticResource StringToVisibilityConverter}}">
                    <TextBlock Text="{Binding ValidationError}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{DynamicResource TextOnPrimaryBrush}"
                               TextWrapping="Wrap" />
                </Border>

                <!-- PAN Type -->
                <StackPanel Margin="{StaticResource Small}">
                    <TextBlock Text="PAN Type"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Margin="{StaticResource ExtraSmall}" />
                    <ComboBox ItemsSource="{Binding PANTypes}"
                              SelectedItem="{Binding PANType}"
                              Height="{StaticResource StandardControlHeight}" />
                </StackPanel>

                <!-- PAN Number -->
                <StackPanel Margin="{StaticResource Small}">
                    <TextBlock Text="PAN Number"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Margin="{StaticResource ExtraSmall}" />
                    <TextBox Text="{Binding PANNumber, UpdateSourceTrigger=PropertyChanged}"
                             Height="{StaticResource StandardControlHeight}" />
                </StackPanel>

                <!-- First Name -->
                <StackPanel Margin="{StaticResource Small}">
                    <TextBlock Text="First Name"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Margin="{StaticResource ExtraSmall}" />
                    <TextBox Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}"
                             Height="{StaticResource StandardControlHeight}" />
                </StackPanel>

                <!-- Middle Name -->
                <StackPanel Margin="{StaticResource Small}">
                    <TextBlock Text="Middle Name"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Margin="{StaticResource ExtraSmall}" />
                    <TextBox Text="{Binding MiddleName, UpdateSourceTrigger=PropertyChanged}"
                             Height="{StaticResource StandardControlHeight}" />
                </StackPanel>

                <!-- Last Name -->
                <StackPanel Margin="{StaticResource Small}">
                    <TextBlock Text="Last Name"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Margin="{StaticResource ExtraSmall}" />
                    <TextBox Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}"
                             Height="{StaticResource StandardControlHeight}" />
                </StackPanel>

                <!-- Company Name -->
                <StackPanel Margin="{StaticResource Small}">
                    <TextBlock Text="Company Name"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Margin="{StaticResource ExtraSmall}" />
                    <TextBox Text="{Binding CompanyName, UpdateSourceTrigger=PropertyChanged}"
                             Height="{StaticResource StandardControlHeight}" />
                </StackPanel>

                <!-- City -->
                <StackPanel Margin="{StaticResource Small}">
                    <TextBlock Text="City"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Margin="{StaticResource ExtraSmall}" />
                    <TextBox Text="{Binding City, UpdateSourceTrigger=PropertyChanged}"
                             Height="{StaticResource StandardControlHeight}" />
                </StackPanel>

                <!-- State -->
                <StackPanel Margin="{StaticResource Small}">
                    <TextBlock Text="State"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Margin="{StaticResource ExtraSmall}" />
                    <TextBox Text="{Binding State, UpdateSourceTrigger=PropertyChanged}"
                             Height="{StaticResource StandardControlHeight}" />
                </StackPanel>

                <!-- Address -->
                <StackPanel Margin="{StaticResource Small}">
                    <TextBlock Text="Address"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Margin="{StaticResource ExtraSmall}" />
                    <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"
                             Height="{StaticResource StandardControlHeight}" />
                </StackPanel>

                <!-- Phone -->
                <StackPanel Margin="{StaticResource Small}">
                    <TextBlock Text="Phone"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Margin="{StaticResource ExtraSmall}" />
                    <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                             Height="{StaticResource StandardControlHeight}" />
                </StackPanel>

                <!-- Mobile -->
                <StackPanel Margin="{StaticResource Small}">
                    <TextBlock Text="Mobile"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Margin="{StaticResource ExtraSmall}" />
                    <TextBox Text="{Binding Mobile, UpdateSourceTrigger=PropertyChanged}"
                             Height="{StaticResource StandardControlHeight}" />
                </StackPanel>

                <!-- Email -->
                <StackPanel Margin="{StaticResource Small}">
                    <TextBlock Text="Email"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Margin="{StaticResource ExtraSmall}" />
                    <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                             Height="{StaticResource StandardControlHeight}" />
                </StackPanel>

                <!-- Fax -->
                <StackPanel Margin="{StaticResource Small}">
                    <TextBlock Text="Fax"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Margin="{StaticResource ExtraSmall}" />
                    <TextBox Text="{Binding Fax, UpdateSourceTrigger=PropertyChanged}"
                             Height="{StaticResource StandardControlHeight}" />
                </StackPanel>

                <!-- Active -->
                <StackPanel Margin="{StaticResource Small}"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <CheckBox IsChecked="{Binding IsActive}"
                              VerticalAlignment="Center"
                              Margin="{StaticResource ExtraSmall}" />
                    <TextBlock Text="Active"
                               Style="{StaticResource BodyTextBlockStyle}"
                               VerticalAlignment="Center"
                               Margin="{StaticResource Small}" />
                </StackPanel>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="{StaticResource Medium}">
                    <Button Content="Save"
                            Command="{Binding SaveCommand}"
                            Height="{StaticResource StandardControlHeight}"
                            Margin="{StaticResource Small}" />

                    <Button Content="Cancel"
                            Command="{Binding CancelCommand}"
                            Height="{StaticResource StandardControlHeight}"
                            Margin="{StaticResource Small}" />
                </StackPanel>

                <!-- Loading Indicator -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="{StaticResource StandardBorderThickness}"
                        CornerRadius="{StaticResource StandardCornerRadius}"
                        Padding="{StaticResource Medium}"
                        Margin="{StaticResource Small}"
                        Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center">
                        <ProgressBar Height="{StaticResource StandardControlHeight}"
                                   IsIndeterminate="True"
                                   Foreground="{DynamicResource PrimaryBrush}"
                                   Margin="{StaticResource Small}" />
                        <TextBlock Text="{Binding BusyMessage}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
