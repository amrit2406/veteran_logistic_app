<UserControl x:Class="veteran_logistic.Masters.Vendors.Views.AddVendorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Background="{DynamicResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="{StaticResource StandardBorderThickness}"
                Padding="{StaticResource Medium}">
            <TextBlock Text="Add Vendor"
                       Style="{StaticResource HeadingTextBlockStyle}"
                       VerticalAlignment="Center" />
        </Border>

        <!-- Form -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="{StaticResource Large}">
            <StackPanel HorizontalAlignment="Left">
                <!-- Validation Error -->
                <Border Background="{DynamicResource ErrorBrush}"
                        BorderBrush="{DynamicResource ErrorBrush}"
                        BorderThickness="{StaticResource StandardBorderThickness}"
                        CornerRadius="{StaticResource StandardCornerRadius}"
                        Padding="{StaticResource Small}"
                        Margin="{StaticResource Small}"
                        Visibility="{Binding ValidationError, Converter={StaticResource StringToVisibilityConverter}}">
                    <TextBlock Text="{Binding ValidationError}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{DynamicResource TextOnPrimaryBrush}"
                               TextWrapping="Wrap" />
                </Border>

                <!-- Code (Auto-generated) -->
                <StackPanel Margin="{StaticResource Small}">
                    <TextBlock Text="Code (Auto-generated)"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Margin="{StaticResource ExtraSmall}" />
                    <TextBox Text="{Binding Code, UpdateSourceTrigger=PropertyChanged}"
                             Height="{StaticResource StandardControlHeight}"
                             IsReadOnly="True" />
                </StackPanel>

                <!-- Type -->
                <StackPanel Margin="{StaticResource Small}">
                    <TextBlock Text="Type"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Margin="{StaticResource ExtraSmall}" />
                    <ComboBox SelectedValue="{Binding Type, UpdateSourceTrigger=PropertyChanged}"
                              SelectedValuePath="Content"
                              Height="{StaticResource StandardControlHeight}">
                        <ComboBoxItem Content="Union" />
                        <ComboBoxItem Content="Vendor" />
                    </ComboBox>
                </StackPanel>

                <!-- Name -->
                <StackPanel Margin="{StaticResource Small}">
                    <TextBlock Text="Name"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Margin="{StaticResource ExtraSmall}" />
                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                             Height="{StaticResource StandardControlHeight}" />
                </StackPanel>

                <!-- Correspondence Address -->
                <StackPanel Margin="{StaticResource Small}">
                    <TextBlock Text="Correspondence Address"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Margin="{StaticResource ExtraSmall}" />
                    <TextBox Text="{Binding CorrespondenceAddress, UpdateSourceTrigger=PropertyChanged}"
                             Height="{StaticResource StandardControlHeight}" />
                </StackPanel>

                <!-- City -->
                <StackPanel Margin="{StaticResource Small}">
                    <TextBlock Text="City"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Margin="{StaticResource ExtraSmall}" />
                    <TextBox Text="{Binding City, UpdateSourceTrigger=PropertyChanged}"
                             Height="{StaticResource StandardControlHeight}" />
                </StackPanel>

                <!-- Billing Address -->
                <StackPanel Margin="{StaticResource Small}">
                    <TextBlock Text="Billing Address"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Margin="{StaticResource ExtraSmall}" />
                    <TextBox Text="{Binding BillingAddress, UpdateSourceTrigger=PropertyChanged}"
                             Height="{StaticResource StandardControlHeight}" />
                </StackPanel>

                <!-- Phone -->
                <StackPanel Margin="{StaticResource Small}">
                    <TextBlock Text="Phone"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Margin="{StaticResource ExtraSmall}" />
                    <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                             Height="{StaticResource StandardControlHeight}" />
                </StackPanel>

                <!-- Mobile -->
                <StackPanel Margin="{StaticResource Small}">
                    <TextBlock Text="Mobile"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Margin="{StaticResource ExtraSmall}" />
                    <TextBox Text="{Binding Mobile, UpdateSourceTrigger=PropertyChanged}"
                             Height="{StaticResource StandardControlHeight}" />
                </StackPanel>

                <!-- Fax -->
                <StackPanel Margin="{StaticResource Small}">
                    <TextBlock Text="Fax"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Margin="{StaticResource ExtraSmall}" />
                    <TextBox Text="{Binding Fax, UpdateSourceTrigger=PropertyChanged}"
                             Height="{StaticResource StandardControlHeight}" />
                </StackPanel>

                <!-- Email -->
                <StackPanel Margin="{StaticResource Small}">
                    <TextBlock Text="Email"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Margin="{StaticResource ExtraSmall}" />
                    <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                             Height="{StaticResource StandardControlHeight}" />
                </StackPanel>

                <!-- Service Tax -->
                <StackPanel Margin="{StaticResource Small}">
                    <TextBlock Text="Service Tax"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Margin="{StaticResource ExtraSmall}" />
                    <TextBox Text="{Binding ServiceTax, UpdateSourceTrigger=PropertyChanged}"
                             Height="{StaticResource StandardControlHeight}" />
                </StackPanel>

                <!-- CST -->
                <StackPanel Margin="{StaticResource Small}">
                    <TextBlock Text="CST"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Margin="{StaticResource ExtraSmall}" />
                    <TextBox Text="{Binding CST, UpdateSourceTrigger=PropertyChanged}"
                             Height="{StaticResource StandardControlHeight}" />
                </StackPanel>

                <!-- PAN -->
                <StackPanel Margin="{StaticResource Small}">
                    <TextBlock Text="PAN"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Margin="{StaticResource ExtraSmall}" />
                    <TextBox Text="{Binding PAN, UpdateSourceTrigger=PropertyChanged}"
                             Height="{StaticResource StandardControlHeight}" />
                </StackPanel>

                <!-- GSTIN -->
                <StackPanel Margin="{StaticResource Small}">
                    <TextBlock Text="GSTIN"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Margin="{StaticResource ExtraSmall}" />
                    <TextBox Text="{Binding GSTIN, UpdateSourceTrigger=PropertyChanged}"
                             Height="{StaticResource StandardControlHeight}" />
                </StackPanel>

                <!-- Active -->
                <StackPanel Margin="{StaticResource Small}"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <CheckBox IsChecked="{Binding IsActive}"
                              VerticalAlignment="Center"
                              Margin="{StaticResource ExtraSmall}" />
                    <TextBlock Text="Active"
                               Style="{StaticResource BodyTextBlockStyle}"
                               VerticalAlignment="Center"
                               Margin="{StaticResource Small}" />
                </StackPanel>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="{StaticResource Medium}">
                    <Button Content="Save"
                            Command="{Binding SaveCommand}"
                            Height="{StaticResource StandardControlHeight}"
                            Margin="{StaticResource Small}" />

                    <Button Content="Cancel"
                            Command="{Binding CancelCommand}"
                            Height="{StaticResource StandardControlHeight}"
                            Margin="{StaticResource Small}" />
                </StackPanel>

                <!-- Loading Indicator -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="{StaticResource StandardBorderThickness}"
                        CornerRadius="{StaticResource StandardCornerRadius}"
                        Padding="{StaticResource Medium}"
                        Margin="{StaticResource Small}"
                        Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center">
                        <ProgressBar Height="{StaticResource StandardControlHeight}"
                                   IsIndeterminate="True"
                                   Foreground="{DynamicResource PrimaryBrush}"
                                   Margin="{StaticResource Small}" />
                        <TextBlock Text="{Binding BusyMessage}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
