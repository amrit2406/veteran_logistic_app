<UserControl x:Class="veteran_logistic.Masters.DORates.Views.EditDORateView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="LightGray"
                BorderBrush="Gray"
                BorderThickness="1"
                Padding="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Edit DO Rate"
                           FontSize="16"
                           FontWeight="Bold"
                           VerticalAlignment="Center" />

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <!-- Save Button -->
                    <Button Height="30"
                            Command="{Binding SaveCommand}"
                            VerticalAlignment="Center"
                            Margin="4">
                        <TextBlock Text="Save" />
                    </Button>

                    <!-- Cancel Button -->
                    <Button Height="30"
                            Command="{Binding CancelCommand}"
                            VerticalAlignment="Center"
                            Margin="4">
                        <TextBlock Text="Cancel" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Loading Indicator -->
        <Border Grid.Row="1"
                Background="LightGray"
                BorderBrush="Gray"
                BorderThickness="1"
                Padding="8"
                Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">
                <ProgressBar Height="30"
                           IsIndeterminate="True"
                           Foreground="Blue"
                           Margin="4" />
                <TextBlock Text="{Binding BusyMessage}"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Form -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="16">
            <StackPanel MaxWidth="800" HorizontalAlignment="Center">
                <!-- Validation Error -->
                <Border Background="Red"
                        BorderBrush="DarkRed"
                        BorderThickness="1"
                        Padding="8"
                        Margin="0,0,0,8"
                        Visibility="{Binding ValidationError, Converter={StaticResource StringToVisibilityConverter}}">
                    <TextBlock Text="{Binding ValidationError}"
                               Foreground="White"
                               TextWrapping="Wrap" />
                </Border>

                <!-- Consignor -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Consignor"
                               VerticalAlignment="Center" />
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding Consignors}"
                              DisplayMemberPath="Name"
                              SelectedValuePath="Id"
                              SelectedValue="{Binding ConsignorId}"
                              Height="30" />
                </Grid>

                <!-- Consignee -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Consignee"
                               VerticalAlignment="Center" />
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding Consignees}"
                              DisplayMemberPath="Name"
                              SelectedValuePath="Id"
                              SelectedValue="{Binding ConsigneeId}"
                              Height="30" />
                </Grid>

                <!-- Source -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Source"
                               VerticalAlignment="Center" />
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding SourceDestinations}"
                              DisplayMemberPath="LocationName"
                              SelectedValuePath="Id"
                              SelectedValue="{Binding SourceId}"
                              Height="30" />
                </Grid>

                <!-- Destination -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Destination"
                               VerticalAlignment="Center" />
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding SourceDestinations}"
                              DisplayMemberPath="LocationName"
                              SelectedValuePath="Id"
                              SelectedValue="{Binding DestinationId}"
                              Height="30" />
                </Grid>

                <!-- Effective Date -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Effective Date"
                               VerticalAlignment="Center" />
                    <DatePicker Grid.Column="1"
                                SelectedDate="{Binding EffectiveDate}"
                                Height="30" />
                </Grid>

                <!-- DO Number -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="DO Number"
                               VerticalAlignment="Center" />
                    <TextBox Grid.Column="1"
                             Text="{Binding DONumber, UpdateSourceTrigger=PropertyChanged}"
                             Height="30" />
                </Grid>

                <!-- DO Qty -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="DO Qty"
                               VerticalAlignment="Center" />
                    <TextBox Grid.Column="1"
                             Text="{Binding DOQty, UpdateSourceTrigger=PropertyChanged}"
                             Height="30" />
                </Grid>

                <!-- Freight Rate -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Freight Rate"
                               VerticalAlignment="Center" />
                    <TextBox Grid.Column="1"
                             Text="{Binding FreightRate, UpdateSourceTrigger=PropertyChanged}"
                             Height="30" />
                </Grid>

                <!-- Union Rate -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Union Rate"
                               VerticalAlignment="Center" />
                    <TextBox Grid.Column="1"
                             Text="{Binding UnionRate, UpdateSourceTrigger=PropertyChanged}"
                             Height="30" />
                </Grid>

                <!-- Vendor Rate -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Vendor Rate"
                               VerticalAlignment="Center" />
                    <TextBox Grid.Column="1"
                             Text="{Binding VendorRate, UpdateSourceTrigger=PropertyChanged}"
                             Height="30" />
                </Grid>

                <!-- Billing Rate -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Billing Rate"
                               VerticalAlignment="Center" />
                    <TextBox Grid.Column="1"
                             Text="{Binding BillingRate, UpdateSourceTrigger=PropertyChanged}"
                             Height="30" />
                </Grid>

                <!-- Allowed Shortage -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Allowed Shortage"
                               VerticalAlignment="Center" />
                    <TextBox Grid.Column="1"
                             Text="{Binding AllowedShortage, UpdateSourceTrigger=PropertyChanged}"
                             Height="30" />
                </Grid>

                <!-- Rate Per Kg -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Rate Per Kg"
                               VerticalAlignment="Center" />
                    <TextBox Grid.Column="1"
                             Text="{Binding RatePerKg, UpdateSourceTrigger=PropertyChanged}"
                             Height="30" />
                </Grid>

                <!-- Vessel Name -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Vessel Name"
                               VerticalAlignment="Center" />
                    <TextBox Grid.Column="1"
                             Text="{Binding VesselName, UpdateSourceTrigger=PropertyChanged}"
                             Height="30" />
                </Grid>

                <!-- Trader Name -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Trader Name"
                               VerticalAlignment="Center" />
                    <TextBox Grid.Column="1"
                             Text="{Binding TraderName, UpdateSourceTrigger=PropertyChanged}"
                             Height="30" />
                </Grid>

                <!-- Narration -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Narration"
                               VerticalAlignment="Top"
                               Margin="0,8,0,0" />
                    <TextBox Grid.Column="1"
                             Text="{Binding Narration, UpdateSourceTrigger=PropertyChanged}"
                             Height="80"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto" />
                </Grid>

                <!-- IsActive -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Active"
                               VerticalAlignment="Center" />
                    <CheckBox Grid.Column="1"
                              IsChecked="{Binding IsActive}"
                              VerticalAlignment="Center" />
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
