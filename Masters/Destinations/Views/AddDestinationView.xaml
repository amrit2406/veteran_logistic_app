<UserControl x:Class="veteran_logistic.Masters.Destinations.Views.AddDestinationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Background="{DynamicResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="{StaticResource StandardBorderThickness}"
                Padding="{StaticResource Medium}">
            <TextBlock Text="Add Destination"
                       Style="{StaticResource HeadingTextBlockStyle}"
                       VerticalAlignment="Center" />
        </Border>

        <!-- Form -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="{StaticResource Large}">
            <StackPanel HorizontalAlignment="Left">
                <!-- Validation Error -->
                <Border Background="{DynamicResource ErrorBrush}"
                        BorderBrush="{DynamicResource ErrorBrush}"
                        BorderThickness="{StaticResource StandardBorderThickness}"
                        CornerRadius="{StaticResource StandardCornerRadius}"
                        Padding="{StaticResource Small}"
                        Margin="{StaticResource Small}"
                        Visibility="{Binding ValidationError, Converter={StaticResource StringToVisibilityConverter}}">
                    <TextBlock Text="{Binding ValidationError}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{DynamicResource TextOnPrimaryBrush}"
                               TextWrapping="Wrap" />
                </Border>

                <!-- Destination Code -->
                <StackPanel Margin="{StaticResource Small}">
                    <TextBlock Text="Destination Code"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Margin="{StaticResource ExtraSmall}" />
                    <TextBox Text="{Binding DestinationCode, UpdateSourceTrigger=PropertyChanged}"
                             Height="{StaticResource StandardControlHeight}" />
                </StackPanel>

                <!-- Destination Name -->
                <StackPanel Margin="{StaticResource Small}">
                    <TextBlock Text="Destination Name"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Margin="{StaticResource ExtraSmall}" />
                    <TextBox Text="{Binding DestinationName, UpdateSourceTrigger=PropertyChanged}"
                             Height="{StaticResource StandardControlHeight}" />
                </StackPanel>

                <!-- Address Line 1 -->
                <StackPanel Margin="{StaticResource Small}">
                    <TextBlock Text="Address Line 1"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Margin="{StaticResource ExtraSmall}" />
                    <TextBox Text="{Binding AddressLine1, UpdateSourceTrigger=PropertyChanged}"
                             Height="{StaticResource StandardControlHeight}" />
                </StackPanel>

                <!-- Address Line 2 -->
                <StackPanel Margin="{StaticResource Small}">
                    <TextBlock Text="Address Line 2"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Margin="{StaticResource ExtraSmall}" />
                    <TextBox Text="{Binding AddressLine2, UpdateSourceTrigger=PropertyChanged}"
                             Height="{StaticResource StandardControlHeight}" />
                </StackPanel>

                <!-- City -->
                <StackPanel Margin="{StaticResource Small}">
                    <TextBlock Text="City"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Margin="{StaticResource ExtraSmall}" />
                    <TextBox Text="{Binding City, UpdateSourceTrigger=PropertyChanged}"
                             Height="{StaticResource StandardControlHeight}" />
                </StackPanel>

                <!-- State -->
                <StackPanel Margin="{StaticResource Small}">
                    <TextBlock Text="State"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Margin="{StaticResource ExtraSmall}" />
                    <TextBox Text="{Binding State, UpdateSourceTrigger=PropertyChanged}"
                             Height="{StaticResource StandardControlHeight}" />
                </StackPanel>

                <!-- Country -->
                <StackPanel Margin="{StaticResource Small}">
                    <TextBlock Text="Country"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Margin="{StaticResource ExtraSmall}" />
                    <TextBox Text="{Binding Country, UpdateSourceTrigger=PropertyChanged}"
                             Height="{StaticResource StandardControlHeight}" />
                </StackPanel>

                <!-- Postal Code -->
                <StackPanel Margin="{StaticResource Small}">
                    <TextBlock Text="Postal Code"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Margin="{StaticResource ExtraSmall}" />
                    <TextBox Text="{Binding PostalCode, UpdateSourceTrigger=PropertyChanged}"
                             Height="{StaticResource StandardControlHeight}" />
                </StackPanel>

                <!-- Contact Person -->
                <StackPanel Margin="{StaticResource Small}">
                    <TextBlock Text="Contact Person"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Margin="{StaticResource ExtraSmall}" />
                    <TextBox Text="{Binding ContactPerson, UpdateSourceTrigger=PropertyChanged}"
                             Height="{StaticResource StandardControlHeight}" />
                </StackPanel>

                <!-- Phone Number -->
                <StackPanel Margin="{StaticResource Small}">
                    <TextBlock Text="Phone Number"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Margin="{StaticResource ExtraSmall}" />
                    <TextBox Text="{Binding PhoneNumber, UpdateSourceTrigger=PropertyChanged}"
                             Height="{StaticResource StandardControlHeight}" />
                </StackPanel>

                <!-- Email -->
                <StackPanel Margin="{StaticResource Small}">
                    <TextBlock Text="Email"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Margin="{StaticResource ExtraSmall}" />
                    <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                             Height="{StaticResource StandardControlHeight}" />
                </StackPanel>

                <!-- GST Number -->
                <StackPanel Margin="{StaticResource Small}">
                    <TextBlock Text="GST Number"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Margin="{StaticResource ExtraSmall}" />
                    <TextBox Text="{Binding GSTNumber, UpdateSourceTrigger=PropertyChanged}"
                             Height="{StaticResource StandardControlHeight}" />
                </StackPanel>

                <!-- Latitude -->
                <StackPanel Margin="{StaticResource Small}">
                    <TextBlock Text="Latitude"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Margin="{StaticResource ExtraSmall}" />
                    <TextBox Text="{Binding Latitude, UpdateSourceTrigger=PropertyChanged}"
                             Height="{StaticResource StandardControlHeight}" />
                </StackPanel>

                <!-- Longitude -->
                <StackPanel Margin="{StaticResource Small}">
                    <TextBlock Text="Longitude"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Margin="{StaticResource ExtraSmall}" />
                    <TextBox Text="{Binding Longitude, UpdateSourceTrigger=PropertyChanged}"
                             Height="{StaticResource StandardControlHeight}" />
                </StackPanel>

                <!-- Remarks -->
                <StackPanel Margin="{StaticResource Small}">
                    <TextBlock Text="Remarks"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Margin="{StaticResource ExtraSmall}" />
                    <TextBox Text="{Binding Remarks, UpdateSourceTrigger=PropertyChanged}"
                             Height="{StaticResource StandardControlHeight}" />
                </StackPanel>

                <!-- Active -->
                <StackPanel Margin="{StaticResource Small}"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <CheckBox IsChecked="{Binding IsActive}"
                              VerticalAlignment="Center"
                              Margin="{StaticResource ExtraSmall}" />
                    <TextBlock Text="Active"
                               Style="{StaticResource BodyTextBlockStyle}"
                               VerticalAlignment="Center"
                               Margin="{StaticResource Small}" />
                </StackPanel>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="{StaticResource Medium}">
                    <Button Content="Save"
                            Command="{Binding SaveCommand}"
                            Height="{StaticResource StandardControlHeight}"
                            Margin="{StaticResource Small}" />

                    <Button Content="Cancel"
                            Command="{Binding CancelCommand}"
                            Height="{StaticResource StandardControlHeight}"
                            Margin="{StaticResource Small}" />
                </StackPanel>

                <!-- Loading Indicator -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="{StaticResource StandardBorderThickness}"
                        CornerRadius="{StaticResource StandardCornerRadius}"
                        Padding="{StaticResource Medium}"
                        Margin="{StaticResource Small}"
                        Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center">
                        <ProgressBar Height="{StaticResource StandardControlHeight}"
                                   IsIndeterminate="True"
                                   Foreground="{DynamicResource PrimaryBrush}"
                                   Margin="{StaticResource Small}" />
                        <TextBlock Text="{Binding BusyMessage}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
