<UserControl x:Class="veteran_logistic.Masters.VehicleAssignments.Views.VehicleAssignmentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:veteran_logistic.Converters"
             mc:Ignorable="d">
    <UserControl.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="LightGray"
                BorderBrush="Gray"
                BorderThickness="1"
                Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Vehicle Assignments"
                           FontSize="16"
                           FontWeight="Bold"
                           VerticalAlignment="Center" />

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="Back"
                            Command="{Binding GoBackCommand}"
                            Width="80"
                            Height="30"
                            Margin="5" />

                    <TextBox Width="150"
                             Height="30"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Margin="5"
                             VerticalAlignment="Center" />

                    <Button Content="Release"
                            Command="{Binding ReleaseVehicleCommand}"
                            Width="80"
                            Height="30"
                            Margin="5" />

                    <Button Content="Delete"
                            Command="{Binding DeleteAssignmentCommand}"
                            Width="80"
                            Height="30"
                            Margin="5" />

                    <Button Content="Refresh"
                            Command="{Binding RefreshCommand}"
                            Width="80"
                            Height="30"
                            Margin="5" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Loading Indicator -->
        <Border Grid.Row="1"
                Background="LightGray"
                BorderBrush="Gray"
                BorderThickness="1"
                Padding="10"
                Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">
                <ProgressBar Height="20"
                           Width="200"
                           IsIndeterminate="True"
                           Margin="10" />
                <TextBlock Text="{Binding BusyMessage}"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Validation Error -->
        <Border Grid.Row="2"
                Background="LightPink"
                BorderBrush="Red"
                BorderThickness="1"
                Padding="10"
                Visibility="{Binding ValidationError, Converter={StaticResource StringToVisibilityConverter}}"
                Margin="5">
            <TextBlock Text="{Binding ValidationError}"
                       TextWrapping="Wrap"
                       Foreground="Red" />
        </Border>

        <!-- Assignment Details -->
        <Border Grid.Row="3"
                Background="LightBlue"
                BorderBrush="Gray"
                BorderThickness="1"
                CornerRadius="5"
                Padding="10"
                Margin="5"
                Visibility="{Binding SelectedAssignment, Converter={StaticResource NullToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Vehicle Details -->
                <Border Grid.Column="0"
                        BorderBrush="Gray"
                        BorderThickness="1"
                        CornerRadius="5"
                        Padding="10"
                        Margin="5">
                    <StackPanel>
                        <TextBlock Text="Vehicle Details"
                                   FontWeight="Bold"
                                   Margin="5" />
                        <TextBlock Text="Vehicle Number:"
                                   Margin="5" />
                        <TextBlock Text="{Binding SelectedAssignment.VehicleNumber}"
                                   Margin="5,0,5,10" />
                        <TextBlock Text="Vehicle Type:"
                                   Margin="5" />
                        <TextBlock Text="{Binding SelectedAssignment.VehicleType}"
                                   Margin="5,0,5,10" />
                        <TextBlock Text="Assign Date:"
                                   Margin="5" />
                        <TextBlock Text="{Binding SelectedAssignment.AssignDate, StringFormat='{}{0:dd-MM-yyyy}'}"
                                   Margin="5,0,5,10" />
                        <TextBlock Text="Release Date:"
                                   Margin="5" />
                        <TextBlock Text="{Binding SelectedAssignment.ReleaseDate, StringFormat='{}{0:dd-MM-yyyy}'}"
                                   Margin="5,0,5,10" />
                    </StackPanel>
                </Border>

                <!-- Owner Details -->
                <Border Grid.Column="1"
                        BorderBrush="Gray"
                        BorderThickness="1"
                        CornerRadius="5"
                        Padding="10"
                        Margin="5">
                    <StackPanel>
                        <TextBlock Text="Owner Details"
                                   FontWeight="Bold"
                                   Margin="5" />
                        <TextBlock Text="PAN Type:"
                                   Margin="5" />
                        <TextBlock Text="{Binding SelectedAssignment.PANType}"
                                   Margin="5,0,5,10" />
                        <TextBlock Text="PAN Number:"
                                   Margin="5" />
                        <TextBlock Text="{Binding SelectedAssignment.PANNumber}"
                                   Margin="5,0,5,10" />
                        <TextBlock Text="First Name:"
                                   Margin="5" />
                        <TextBlock Text="{Binding SelectedAssignment.FirstName}"
                                   Margin="5,0,5,10" />
                        <TextBlock Text="Middle Name:"
                                   Margin="5" />
                        <TextBlock Text="{Binding SelectedAssignment.MiddleName}"
                                   Margin="5,0,5,10" />
                        <TextBlock Text="Last Name:"
                                   Margin="5" />
                        <TextBlock Text="{Binding SelectedAssignment.LastName}"
                                   Margin="5,0,5,10" />
                        <TextBlock Text="Address:"
                                   Margin="5" />
                        <TextBlock Text="{Binding SelectedAssignment.Address}"
                                   Margin="5,0,5,10" />
                        <TextBlock Text="Mobile:"
                                   Margin="5" />
                        <TextBlock Text="{Binding SelectedAssignment.Mobile}"
                                   Margin="5,0,5,10" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- DataGrid -->
        <DataGrid Grid.Row="4"
                  ItemsSource="{Binding VehicleAssignments}"
                  SelectedItem="{Binding SelectedAssignment}"
                  IsReadOnly="True"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserReorderColumns="False"
                  SelectionMode="Single"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  Background="White"
                  BorderThickness="1"
                  BorderBrush="Gray"
                  RowBackground="White"
                  AlternatingRowBackground="LightGray">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Vehicle Number"
                                    Binding="{Binding VehicleNumber}"
                                    Width="Auto" />

                <DataGridTextColumn Header="Vehicle Type"
                                    Binding="{Binding VehicleType}"
                                    Width="Auto" />

                <DataGridTextColumn Header="Owner Name"
                                    Binding="{Binding OwnerName}"
                                    Width="*" />

                <DataGridTextColumn Header="PAN"
                                    Binding="{Binding PANNumber}"
                                    Width="Auto" />

                <DataGridTextColumn Header="Assign Date"
                                    Binding="{Binding AssignDate, StringFormat='{}{0:dd-MM-yyyy}'}"
                                    Width="Auto" />

                <DataGridTextColumn Header="Release Date"
                                    Binding="{Binding ReleaseDate, StringFormat='{}{0:dd-MM-yyyy}'}"
                                    Width="Auto" />

                <DataGridTextColumn Header="Status"
                                    Binding="{Binding Status}"
                                    Width="Auto" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
