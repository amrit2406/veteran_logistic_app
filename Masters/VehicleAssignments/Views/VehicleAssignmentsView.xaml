<UserControl x:Class="veteran_logistic.Masters.VehicleAssignments.Views.VehicleAssignmentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:veteran_logistic.Converters"
             mc:Ignorable="d">
    <UserControl.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
    </UserControl.Resources>
    <Grid Background="{DynamicResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="{StaticResource StandardBorderThickness}"
                Padding="{StaticResource Medium}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Vehicle Assignment"
                           Style="{StaticResource HeadingTextBlockStyle}"
                           VerticalAlignment="Center" />

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <!-- Back Button -->
                    <Button Height="{StaticResource StandardControlHeight}"
                            Command="{Binding GoBackCommand}"
                            IsEnabled="{Binding CanGoBack}"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Go Back"
                            VerticalAlignment="Center"
                            Margin="{StaticResource Small}">
                        <Viewbox Width="16" Height="16">
                            <Path Data="{StaticResource BackIconGeometry}"
                                  Fill="{DynamicResource TextPrimaryBrush}" />
                        </Viewbox>
                    </Button>

                    <!-- Search Box -->
                    <TextBox Height="{StaticResource StandardControlHeight}"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Margin="{StaticResource Small}"
                             VerticalAlignment="Center"
                             Width="200">
                        <TextBox.Style>
                            <Style BasedOn="{StaticResource BaseTextBoxStyle}" TargetType="TextBox">
                                <Setter Property="Padding" Value="{StaticResource Small}" />
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <!-- Search Button -->
                    <Button Height="{StaticResource StandardControlHeight}"
                            Command="{Binding SearchVehicleCommand}"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Search"
                            VerticalAlignment="Center"
                            Margin="{StaticResource Small}">
                        <TextBlock Text="Search"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>

                    <!-- Clear Button -->
                    <Button Height="{StaticResource StandardControlHeight}"
                            Command="{Binding ClearScreenCommand}"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Clear"
                            VerticalAlignment="Center"
                            Margin="{StaticResource Small}">
                        <TextBlock Text="Clear"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>

                    <!-- Refresh Button -->
                    <Button Height="{StaticResource StandardControlHeight}"
                            Command="{Binding RefreshCommand}"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Refresh"
                            VerticalAlignment="Center"
                            Margin="{StaticResource Small}">
                        <TextBlock Text="Refresh"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Loading Indicator -->
        <Border Grid.Row="1"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="{StaticResource StandardBorderThickness}"
                Padding="{StaticResource Medium}"
                Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">
                <ProgressBar Height="{StaticResource StandardControlHeight}"
                           IsIndeterminate="True"
                           Foreground="{DynamicResource PrimaryBrush}"
                           Margin="{StaticResource Small}" />
                <TextBlock Text="{Binding BusyMessage}"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Validation Error -->
        <Border Grid.Row="2"
                Background="{DynamicResource ErrorBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="{StaticResource StandardBorderThickness}"
                Padding="{StaticResource Medium}"
                Visibility="{Binding ValidationError, Converter={StaticResource StringToVisibilityConverter}}"
                Margin="{StaticResource Small}">
            <TextBlock Text="{Binding ValidationError}"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{DynamicResource OnErrorBrush}"
                       TextWrapping="Wrap" />
        </Border>

        <!-- Vehicle Assignment Details -->
        <ScrollViewer Grid.Row="3"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="{StaticResource Medium}"
                        Visibility="{Binding VehicleFound, Converter={StaticResource BooleanToVisibilityConverter}}">
                <!-- Vehicle Details Section -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="{StaticResource StandardBorderThickness}"
                        Padding="{StaticResource Medium}"
                        Margin="{StaticResource Small}">
                    <StackPanel>
                        <TextBlock Text="Vehicle Details"
                                   Style="{StaticResource SubHeadingTextBlockStyle}"
                                   Margin="{StaticResource Small}" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Vehicle Number -->
                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="Vehicle Number:"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       VerticalAlignment="Center"
                                       Margin="{StaticResource Small}"
                                       Padding="{StaticResource Small}" />
                            <TextBox Grid.Row="0" Grid.Column="1"
                                     Text="{Binding VehicleAssignment.VehicleNumber}"
                                     IsReadOnly="True"
                                     Margin="{StaticResource Small}"
                                     Padding="{StaticResource Small}">
                                <TextBox.Style>
                                    <Style BasedOn="{StaticResource BaseTextBoxStyle}" TargetType="TextBox">
                                        <Setter Property="Background" Value="{DynamicResource BackgroundBrush}" />
                                    </Style>
                                </TextBox.Style>
                            </TextBox>

                            <!-- Vehicle Type -->
                            <TextBlock Grid.Row="1" Grid.Column="0"
                                       Text="Vehicle Type:"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       VerticalAlignment="Center"
                                       Margin="{StaticResource Small}"
                                       Padding="{StaticResource Small}" />
                            <TextBox Grid.Row="1" Grid.Column="1"
                                     Text="{Binding VehicleAssignment.VehicleType}"
                                     IsReadOnly="True"
                                     Margin="{StaticResource Small}"
                                     Padding="{StaticResource Small}">
                                <TextBox.Style>
                                    <Style BasedOn="{StaticResource BaseTextBoxStyle}" TargetType="TextBox">
                                        <Setter Property="Background" Value="{DynamicResource BackgroundBrush}" />
                                    </Style>
                                </TextBox.Style>
                            </TextBox>

                            <!-- Assign Date -->
                            <TextBlock Grid.Row="2" Grid.Column="0"
                                       Text="Assign Date:"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       VerticalAlignment="Center"
                                       Margin="{StaticResource Small}"
                                       Padding="{StaticResource Small}" />
                            <TextBox Grid.Row="2" Grid.Column="1"
                                     Text="{Binding VehicleAssignment.AssignDate, StringFormat=dd-MM-yyyy}"
                                     IsReadOnly="True"
                                     Margin="{StaticResource Small}"
                                     Padding="{StaticResource Small}">
                                <TextBox.Style>
                                    <Style BasedOn="{StaticResource BaseTextBoxStyle}" TargetType="TextBox">
                                        <Setter Property="Background" Value="{DynamicResource BackgroundBrush}" />
                                    </Style>
                                </TextBox.Style>
                            </TextBox>

                            <!-- Release Date -->
                            <TextBlock Grid.Row="3" Grid.Column="0"
                                       Text="Release Date:"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       VerticalAlignment="Center"
                                       Margin="{StaticResource Small}"
                                       Padding="{StaticResource Small}" />
                            <TextBox Grid.Row="3" Grid.Column="1"
                                     Text="{Binding VehicleAssignment.ReleaseDate, StringFormat=dd-MM-yyyy}"
                                     IsReadOnly="True"
                                     Margin="{StaticResource Small}"
                                     Padding="{StaticResource Small}">
                                <TextBox.Style>
                                    <Style BasedOn="{StaticResource BaseTextBoxStyle}" TargetType="TextBox">
                                        <Setter Property="Background" Value="{DynamicResource BackgroundBrush}" />
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Owner Details Section -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="{StaticResource StandardBorderThickness}"
                        Padding="{StaticResource Medium}"
                        Margin="{StaticResource Small}">
                    <StackPanel>
                        <TextBlock Text="Owner Details"
                                   Style="{StaticResource SubHeadingTextBlockStyle}"
                                   Margin="{StaticResource Small}" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- PAN Type -->
                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="PAN Type:"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       VerticalAlignment="Center"
                                       Margin="{StaticResource Small}"
                                       Padding="{StaticResource Small}" />
                            <TextBox Grid.Row="0" Grid.Column="1"
                                     Text="{Binding VehicleAssignment.PANType}"
                                     IsReadOnly="True"
                                     Margin="{StaticResource Small}"
                                     Padding="{StaticResource Small}">
                                <TextBox.Style>
                                    <Style BasedOn="{StaticResource BaseTextBoxStyle}" TargetType="TextBox">
                                        <Setter Property="Background" Value="{DynamicResource BackgroundBrush}" />
                                    </Style>
                                </TextBox.Style>
                            </TextBox>

                            <!-- PAN Number -->
                            <TextBlock Grid.Row="1" Grid.Column="0"
                                       Text="PAN Number:"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       VerticalAlignment="Center"
                                       Margin="{StaticResource Small}"
                                       Padding="{StaticResource Small}" />
                            <TextBox Grid.Row="1" Grid.Column="1"
                                     Text="{Binding VehicleAssignment.PANNumber}"
                                     IsReadOnly="True"
                                     Margin="{StaticResource Small}"
                                     Padding="{StaticResource Small}">
                                <TextBox.Style>
                                    <Style BasedOn="{StaticResource BaseTextBoxStyle}" TargetType="TextBox">
                                        <Setter Property="Background" Value="{DynamicResource BackgroundBrush}" />
                                    </Style>
                                </TextBox.Style>
                            </TextBox>

                            <!-- First Name -->
                            <TextBlock Grid.Row="2" Grid.Column="0"
                                       Text="First Name:"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       VerticalAlignment="Center"
                                       Margin="{StaticResource Small}"
                                       Padding="{StaticResource Small}" />
                            <TextBox Grid.Row="2" Grid.Column="1"
                                     Text="{Binding VehicleAssignment.FirstName}"
                                     IsReadOnly="True"
                                     Margin="{StaticResource Small}"
                                     Padding="{StaticResource Small}">
                                <TextBox.Style>
                                    <Style BasedOn="{StaticResource BaseTextBoxStyle}" TargetType="TextBox">
                                        <Setter Property="Background" Value="{DynamicResource BackgroundBrush}" />
                                    </Style>
                                </TextBox.Style>
                            </TextBox>

                            <!-- Middle Name -->
                            <TextBlock Grid.Row="3" Grid.Column="0"
                                       Text="Middle Name:"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       VerticalAlignment="Center"
                                       Margin="{StaticResource Small}"
                                       Padding="{StaticResource Small}" />
                            <TextBox Grid.Row="3" Grid.Column="1"
                                     Text="{Binding VehicleAssignment.MiddleName}"
                                     IsReadOnly="True"
                                     Margin="{StaticResource Small}"
                                     Padding="{StaticResource Small}">
                                <TextBox.Style>
                                    <Style BasedOn="{StaticResource BaseTextBoxStyle}" TargetType="TextBox">
                                        <Setter Property="Background" Value="{DynamicResource BackgroundBrush}" />
                                    </Style>
                                </TextBox.Style>
                            </TextBox>

                            <!-- Last Name -->
                            <TextBlock Grid.Row="4" Grid.Column="0"
                                       Text="Last Name:"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       VerticalAlignment="Center"
                                       Margin="{StaticResource Small}"
                                       Padding="{StaticResource Small}" />
                            <TextBox Grid.Row="4" Grid.Column="1"
                                     Text="{Binding VehicleAssignment.LastName}"
                                     IsReadOnly="True"
                                     Margin="{StaticResource Small}"
                                     Padding="{StaticResource Small}">
                                <TextBox.Style>
                                    <Style BasedOn="{StaticResource BaseTextBoxStyle}" TargetType="TextBox">
                                        <Setter Property="Background" Value="{DynamicResource BackgroundBrush}" />
                                    </Style>
                                </TextBox.Style>
                            </TextBox>

                            <!-- Address -->
                            <TextBlock Grid.Row="5" Grid.Column="0"
                                       Text="Address:"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       VerticalAlignment="Top"
                                       Margin="{StaticResource Small}"
                                       Padding="{StaticResource Small}" />
                            <TextBox Grid.Row="5" Grid.Column="1"
                                     Text="{Binding VehicleAssignment.Address}"
                                     IsReadOnly="True"
                                     Margin="{StaticResource Small}"
                                     Padding="{StaticResource Small}"
                                     Height="60"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto">
                                <TextBox.Style>
                                    <Style BasedOn="{StaticResource BaseTextBoxStyle}" TargetType="TextBox">
                                        <Setter Property="Background" Value="{DynamicResource BackgroundBrush}" />
                                    </Style>
                                </TextBox.Style>
                            </TextBox>

                            <!-- Mobile Number -->
                            <TextBlock Grid.Row="6" Grid.Column="0"
                                       Text="Mobile Number:"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       VerticalAlignment="Center"
                                       Margin="{StaticResource Small}"
                                       Padding="{StaticResource Small}" />
                            <TextBox Grid.Row="6" Grid.Column="1"
                                     Text="{Binding VehicleAssignment.MobileNumber}"
                                     IsReadOnly="True"
                                     Margin="{StaticResource Small}"
                                     Padding="{StaticResource Small}">
                                <TextBox.Style>
                                    <Style BasedOn="{StaticResource BaseTextBoxStyle}" TargetType="TextBox">
                                        <Setter Property="Background" Value="{DynamicResource BackgroundBrush}" />
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- No Vehicle Found Message -->
        <Border Grid.Row="3"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="{StaticResource StandardBorderThickness}"
                Padding="{StaticResource Large}"
                Margin="{StaticResource Medium}"
                Visibility="{Binding ShowNoVehicleFound, Converter={StaticResource BooleanToVisibilityConverter}}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <TextBlock Text="No vehicle found."
                       Style="{StaticResource BodyTextBlockStyle}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
        </Border>
    </Grid>
</UserControl>
