<UserControl x:Class="veteran_logistic.Masters.VehicleAssignments.Views.VehicleAssignmentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:veteran_logistic.Converters"
             mc:Ignorable="d">
    <UserControl.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>
    <Grid Background="{DynamicResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="{StaticResource StandardBorderThickness}"
                Padding="{StaticResource Medium}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Vehicle Assignments"
                           Style="{StaticResource HeadingTextBlockStyle}"
                           VerticalAlignment="Center" />

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <!-- Back Button -->
                    <Button Height="{StaticResource StandardControlHeight}"
                            Command="{Binding GoBackCommand}"
                            IsEnabled="{Binding CanGoBack}"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Go Back"
                            VerticalAlignment="Center"
                            Margin="{StaticResource Small}">
                        <Viewbox Width="16" Height="16">
                            <Path Data="{StaticResource BackIconGeometry}"
                                  Fill="{DynamicResource TextPrimaryBrush}" />
                        </Viewbox>
                    </Button>

                    <!-- Search -->
                    <TextBox Height="{StaticResource StandardControlHeight}"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Margin="{StaticResource Small}"
                             VerticalAlignment="Center">
                        <TextBox.Style>
                            <Style BasedOn="{StaticResource BaseTextBoxStyle}" TargetType="TextBox">
                                <Setter Property="Padding" Value="{StaticResource Small}" />
                            </Style>
                        </TextBox.Style>
                    </TextBox>


                    <!-- Release Vehicle Button -->
                    <Button Height="{StaticResource StandardControlHeight}"
                            Command="{Binding ReleaseVehicleCommand}"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Release Vehicle"
                            VerticalAlignment="Center"
                            Margin="{StaticResource Small}">
                        <TextBlock Text="Release Vehicle"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>

                    <!-- Delete Assignment Button -->
                    <Button Height="{StaticResource StandardControlHeight}"
                            Command="{Binding DeleteAssignmentCommand}"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Delete Assignment"
                            VerticalAlignment="Center"
                            Margin="{StaticResource Small}">
                        <TextBlock Text="Delete Assignment"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>

                    <!-- Refresh Button -->
                    <Button Height="{StaticResource StandardControlHeight}"
                            Command="{Binding RefreshCommand}"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Refresh"
                            VerticalAlignment="Center"
                            Margin="{StaticResource Small}">
                        <TextBlock Text="Refresh"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Loading Indicator -->
        <Border Grid.Row="1"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="{StaticResource StandardBorderThickness}"
                Padding="{StaticResource Medium}"
                Visibility="Collapsed">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">
                <ProgressBar Height="{StaticResource StandardControlHeight}"
                           IsIndeterminate="True"
                           Foreground="{DynamicResource PrimaryBrush}"
                           Margin="{StaticResource Small}" />
                <TextBlock Text="{Binding BusyMessage}"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Validation Error -->
        <Border Grid.Row="2"
                Background="{DynamicResource ErrorBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="{StaticResource StandardBorderThickness}"
                Padding="{StaticResource Medium}"
                Visibility="Collapsed"
                Margin="{StaticResource Small}">
            <TextBlock Text="{Binding ValidationError}"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{DynamicResource OnErrorBrush}"
                       TextWrapping="Wrap" />
        </Border>

        <!-- Assignment Details -->
        <Border Grid.Row="3"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="{StaticResource StandardBorderThickness}"
                CornerRadius="{StaticResource StandardCornerRadius}"
                Padding="{StaticResource Medium}"
                Margin="{StaticResource Small}"
                Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Vehicle Details -->
                <Border Grid.Column="0"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="{StaticResource StandardBorderThickness}"
                        CornerRadius="{StaticResource StandardCornerRadius}"
                        Padding="{StaticResource Medium}"
                        Margin="{StaticResource Small}">
                    <StackPanel>
                        <TextBlock Text="Vehicle Details"
                                   Style="{StaticResource HeadingTextBlockStyle}"
                                   Margin="{StaticResource Small}" />
                        <TextBlock Text="Vehicle Number:"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   Margin="{StaticResource ExtraSmall}" />
                        <TextBlock Text="{Binding SelectedAssignment.VehicleNumber}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Margin="{StaticResource ExtraSmall}" />
                        <TextBlock Text="Vehicle Type:"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   Margin="{StaticResource ExtraSmall}" />
                        <TextBlock Text="{Binding SelectedAssignment.VehicleType}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Margin="{StaticResource ExtraSmall}" />
                    </StackPanel>
                </Border>

                <!-- Owner Details -->
                <Border Grid.Column="1"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="{StaticResource StandardBorderThickness}"
                        CornerRadius="{StaticResource StandardCornerRadius}"
                        Padding="{StaticResource Medium}"
                        Margin="{StaticResource Small}">
                    <StackPanel>
                        <TextBlock Text="Owner Details"
                                   Style="{StaticResource HeadingTextBlockStyle}"
                                   Margin="{StaticResource Small}" />
                        <TextBlock Text="Owner Name:"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   Margin="{StaticResource ExtraSmall}" />
                        <TextBlock Text="{Binding SelectedAssignment.OwnerName}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Margin="{StaticResource ExtraSmall}" />
                        <TextBlock Text="PAN Number:"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   Margin="{StaticResource ExtraSmall}" />
                        <TextBlock Text="{Binding SelectedAssignment.PANNumber}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Margin="{StaticResource ExtraSmall}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- DataGrid -->
        <DataGrid Grid.Row="4"
                  ItemsSource="{Binding VehicleAssignments}"
                  SelectedItem="{Binding SelectedAssignment}"
                  IsReadOnly="True"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserReorderColumns="False"
                  SelectionMode="Single"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  Background="{DynamicResource BackgroundBrush}"
                  BorderThickness="0"
                  RowBackground="{DynamicResource SurfaceBrush}"
                  AlternatingRowBackground="{DynamicResource SurfaceBrush}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Vehicle Number"
                                    Binding="{Binding VehicleNumber}"
                                    Width="Auto" />

                <DataGridTextColumn Header="Vehicle Type"
                                    Binding="{Binding VehicleType}"
                                    Width="Auto" />

                <DataGridTextColumn Header="Owner Name"
                                    Binding="{Binding OwnerName}"
                                    Width="*" />

                <DataGridTextColumn Header="PAN"
                                    Binding="{Binding PANNumber}"
                                    Width="Auto" />

                <DataGridTextColumn Header="Assign Date"
                                    Binding="{Binding AssignDate, StringFormat='{}{0:dd-MM-yyyy}'}"
                                    Width="Auto" />

                <DataGridTextColumn Header="Release Date"
                                    Binding="{Binding ReleaseDate, StringFormat='{}{0:dd-MM-yyyy}'}"
                                    Width="Auto" />

                <DataGridTextColumn Header="Status"
                                    Binding="{Binding Status}"
                                    Width="Auto" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
