<UserControl x:Class="veteran_logistic.Masters.VehicleAssignments.Views.EditVehicleAssignmentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Background="{DynamicResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="{StaticResource StandardBorderThickness}"
                Padding="{StaticResource Medium}">
            <TextBlock Text="Edit Vehicle Assignment"
                       Style="{StaticResource HeadingTextBlockStyle}"
                       VerticalAlignment="Center" />
        </Border>

        <!-- Form -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="{StaticResource Large}">
            <StackPanel HorizontalAlignment="Left">
                <!-- Validation Error -->
                <Border Background="{DynamicResource ErrorBrush}"
                        BorderBrush="{DynamicResource ErrorBrush}"
                        BorderThickness="{StaticResource StandardBorderThickness}"
                        CornerRadius="{StaticResource StandardCornerRadius}"
                        Padding="{StaticResource Small}"
                        Margin="{StaticResource Small}"
                        Visibility="{Binding ValidationError, Converter={StaticResource StringToVisibilityConverter}}">
                    <TextBlock Text="{Binding ValidationError}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{DynamicResource TextOnPrimaryBrush}"
                               TextWrapping="Wrap" />
                </Border>

                <!-- Vehicle Details Section -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="{StaticResource StandardBorderThickness}"
                        CornerRadius="{StaticResource StandardCornerRadius}"
                        Padding="{StaticResource Medium}"
                        Margin="{StaticResource Small}">
                    <StackPanel>
                        <TextBlock Text="Vehicle Details"
                                   Style="{StaticResource HeadingTextBlockStyle}"
                                   Margin="{StaticResource Small}" />

                        <!-- Vehicle Selection -->
                        <StackPanel Margin="{StaticResource Small}">
                            <TextBlock Text="Vehicle Number"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       Margin="{StaticResource ExtraSmall}" />
                            <ComboBox ItemsSource="{Binding Vehicles}"
                                      SelectedValue="{Binding SelectedVehicleId}"
                                      SelectedValuePath="Id"
                                      DisplayMemberPath="VehicleNumber"
                                      Height="{StaticResource StandardControlHeight}" />
                        </StackPanel>

                        <!-- Vehicle Type (Read-only) -->
                        <StackPanel Margin="{StaticResource Small}">
                            <TextBlock Text="Vehicle Type"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       Margin="{StaticResource ExtraSmall}" />
                            <TextBox Text="{Binding VehicleType}"
                                     IsReadOnly="True"
                                     Background="{DynamicResource DisabledBrush}"
                                     Height="{StaticResource StandardControlHeight}" />
                        </StackPanel>

                        <!-- Assign Date -->
                        <StackPanel Margin="{StaticResource Small}">
                            <TextBlock Text="Assign Date"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       Margin="{StaticResource ExtraSmall}" />
                            <DatePicker SelectedDate="{Binding AssignDate}"
                                        Height="{StaticResource StandardControlHeight}" />
                        </StackPanel>

                        <!-- Release Date (Optional) -->
                        <StackPanel Margin="{StaticResource Small}">
                            <TextBlock Text="Release Date (Optional)"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       Margin="{StaticResource ExtraSmall}" />
                            <DatePicker SelectedDate="{Binding ReleaseDate}"
                                        Height="{StaticResource StandardControlHeight}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Owner Details Section -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="{StaticResource StandardBorderThickness}"
                        CornerRadius="{StaticResource StandardCornerRadius}"
                        Padding="{StaticResource Medium}"
                        Margin="{StaticResource Small}">
                    <StackPanel>
                        <TextBlock Text="Owner Details"
                                   Style="{StaticResource HeadingTextBlockStyle}"
                                   Margin="{StaticResource Small}" />

                        <!-- Owner Selection -->
                        <StackPanel Margin="{StaticResource Small}">
                            <TextBlock Text="Vehicle Owner"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       Margin="{StaticResource ExtraSmall}" />
                            <ComboBox ItemsSource="{Binding VehicleOwners}"
                                      SelectedValue="{Binding SelectedVehicleOwnerId}"
                                      SelectedValuePath="Id"
                                      DisplayMemberPath="OwnerName"
                                      Height="{StaticResource StandardControlHeight}" />
                        </StackPanel>

                        <!-- PAN Type (Read-only) -->
                        <StackPanel Margin="{StaticResource Small}">
                            <TextBlock Text="PAN Type"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       Margin="{StaticResource ExtraSmall}" />
                            <TextBox Text="{Binding OwnerPanType}"
                                     IsReadOnly="True"
                                     Background="{DynamicResource DisabledBrush}"
                                     Height="{StaticResource StandardControlHeight}" />
                        </StackPanel>

                        <!-- PAN Number (Read-only) -->
                        <StackPanel Margin="{StaticResource Small}">
                            <TextBlock Text="PAN Number"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       Margin="{StaticResource ExtraSmall}" />
                            <TextBox Text="{Binding OwnerPanNumber}"
                                     IsReadOnly="True"
                                     Background="{DynamicResource DisabledBrush}"
                                     Height="{StaticResource StandardControlHeight}" />
                        </StackPanel>

                        <!-- First Name (Read-only) -->
                        <StackPanel Margin="{StaticResource Small}">
                            <TextBlock Text="First Name"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       Margin="{StaticResource ExtraSmall}" />
                            <TextBox Text="{Binding OwnerFirstName}"
                                     IsReadOnly="True"
                                     Background="{DynamicResource DisabledBrush}"
                                     Height="{StaticResource StandardControlHeight}" />
                        </StackPanel>

                        <!-- Middle Name (Read-only) -->
                        <StackPanel Margin="{StaticResource Small}">
                            <TextBlock Text="Middle Name"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       Margin="{StaticResource ExtraSmall}" />
                            <TextBox Text="{Binding OwnerMiddleName}"
                                     IsReadOnly="True"
                                     Background="{DynamicResource DisabledBrush}"
                                     Height="{StaticResource StandardControlHeight}" />
                        </StackPanel>

                        <!-- Last Name (Read-only) -->
                        <StackPanel Margin="{StaticResource Small}">
                            <TextBlock Text="Last Name"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       Margin="{StaticResource ExtraSmall}" />
                            <TextBox Text="{Binding OwnerLastName}"
                                     IsReadOnly="True"
                                     Background="{DynamicResource DisabledBrush}"
                                     Height="{StaticResource StandardControlHeight}" />
                        </StackPanel>

                        <!-- Address (Read-only) -->
                        <StackPanel Margin="{StaticResource Small}">
                            <TextBlock Text="Address"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       Margin="{StaticResource ExtraSmall}" />
                            <TextBox Text="{Binding OwnerAddress}"
                                     IsReadOnly="True"
                                     Background="{DynamicResource DisabledBrush}"
                                     Height="{StaticResource StandardControlHeight}" />
                        </StackPanel>

                        <!-- Mobile Number (Read-only) -->
                        <StackPanel Margin="{StaticResource Small}">
                            <TextBlock Text="Mobile Number"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       Margin="{StaticResource ExtraSmall}" />
                            <TextBox Text="{Binding OwnerMobileNumber}"
                                     IsReadOnly="True"
                                     Background="{DynamicResource DisabledBrush}"
                                     Height="{StaticResource StandardControlHeight}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Active Status -->
                <StackPanel Margin="{StaticResource Small}"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <CheckBox IsChecked="{Binding IsActive}"
                              VerticalAlignment="Center"
                              Margin="{StaticResource ExtraSmall}" />
                    <TextBlock Text="Active"
                               Style="{StaticResource BodyTextBlockStyle}"
                               VerticalAlignment="Center"
                               Margin="{StaticResource Small}" />
                </StackPanel>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="{StaticResource Medium}">
                    <Button Content="Save"
                            Command="{Binding SaveCommand}"
                            Height="{StaticResource StandardControlHeight}"
                            Margin="{StaticResource Small}" />

                    <Button Content="Cancel"
                            Command="{Binding CancelCommand}"
                            Height="{StaticResource StandardControlHeight}"
                            Margin="{StaticResource Small}" />
                </StackPanel>

                <!-- Loading Indicator -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="{StaticResource StandardBorderThickness}"
                        CornerRadius="{StaticResource StandardCornerRadius}"
                        Padding="{StaticResource Medium}"
                        Margin="{StaticResource Small}"
                        Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center">
                        <ProgressBar Height="{StaticResource StandardControlHeight}"
                                   IsIndeterminate="True"
                                   Foreground="{DynamicResource PrimaryBrush}"
                                   Margin="{StaticResource Small}" />
                        <TextBlock Text="{Binding BusyMessage}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
